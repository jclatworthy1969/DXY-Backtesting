//@version=6
// ─────────────────────────────────────────────────────────────────────────────
// DXY Zone Strategy — Backtest Version
// Converts DXYTradeAlert indicator logic into a Pine Script strategy so that
// TradingView's Strategy Tester automatically tracks all trades, win rate,
// duration, and P&L over the selected date range.
//
// POSITION SIZING NOTE:
//   This strategy uses qty=1 (1 DXY unit). All trades are 1:1 RR so:
//     Win  = +TP_distance DXY units
//     Loss = -SL_distance DXY units
//   To convert to $1,000 risk per trade: every win = +$1,000, every loss = -$1,000
//   (because SL distance = TP distance by design).
//   Total $ P&L = (Wins − Losses) × $1,000
// ─────────────────────────────────────────────────────────────────────────────
strategy("DXY Zone Strategy",
    shorttitle       = "DXY Zone",
    overlay          = true,
    initial_capital  = 100000,
    default_qty_type = strategy.fixed,
    default_qty_value= 1,
    process_orders_on_close = true,
    calc_on_every_tick      = false,
    max_labels_count        = 500,
    commission_type  = strategy.commission.percent,
    commission_value = 0)

// ─── BACKTEST PERIOD ─────────────────────────────────────────────────────────
grp_bt     = "Backtest Period"
start_date = input.time(timestamp("01 Jul 2025 00:00 +0000"), "Start Date", group=grp_bt)
end_date   = input.time(timestamp("30 Apr 2026 23:59 +0000"), "End Date",   group=grp_bt)
in_window  = time >= start_date and time <= end_date

// ─── INPUTS ──────────────────────────────────────────────────────────────────
grp_zone = "Signal Zones"
grp_sess = "Session Window (GMT)"
grp_sig  = "Entry Signals"
grp_htf  = "HTF Bias (Reversal Gate)"
grp_disp = "Display"

attr_enabled    = input.bool(true,  "Enable Attraction Trades",                     group=grp_zone)
attr_min_gap    = input.int( 150,   "Attraction — Min Gap at London Open (pts)",    group=grp_zone, minval=50,  step=25,  tooltip="At London open, price must be at least this many pts from the near zone edge, confirming Tokyo left the zone intact with meaningful separation.")
attr_approach   = input.int( 150,   "Attraction — Min 3-Bar Approach (pts)",        group=grp_zone, minval=50,  step=25,  tooltip="3-bar net move toward the zone must be at least this many pts to confirm an impulsive approach.")
attr_min_reward = input.int( 150,   "Attraction — Min Reward to TP (pts)",          group=grp_zone, minval=50,  step=25,  tooltip="Minimum distance (pts) from entry to TP at the time of the signal.")
attr_near_buf   = input.int(  50,   "Attraction — Near-Edge TP Buffer (pts)",       group=grp_zone, minval=0,   step=10,  tooltip="TP is set to the near zone edge PLUS this buffer. 50 pts = TP sits 50 pts inside the zone from the near edge.")
zone_min_gap    = input.int(  30,   "Zone — Min Gap to use open gap (pts)",         group=grp_zone, minval=5,   step=5)
zone_min_width  = input.int( 150,   "Zone — Min Width (pts)",                       group=grp_zone, minval=50,  step=25,  tooltip="Zone must be at least this wide for attraction trades to fire.")
rev_enabled     = input.bool(true,  "Enable Reversal Trades",                       group=grp_zone)
rev_max_dist    = input.int( 500,   "Reversal — Max Distance from Zone (pts)",      group=grp_zone, minval=50,  step=50,  tooltip="Reversal entry only fires when price is within this many pts of the zone edge.")
rev_min_body    = input.int( 200,   "Reversal — Min Signal Candle Body (pts)",      group=grp_zone, minval=0,   step=25)
rev_min_range   = input.int( 400,   "Reversal — Min Signal Candle Range (pts)",     group=grp_zone, minval=0,   step=25)

entry_start_h = input.int(7,  "Entry Start Hour (GMT)",          group=grp_sess)
entry_start_m = input.int(30, "Entry Start Min  (GMT)",          group=grp_sess)
entry_end_h   = input.int(19, "Entry End Hour   (GMT)",          group=grp_sess)
entry_end_m   = input.int(30, "Entry End Min    (GMT)",          group=grp_sess)
rev_end_h     = input.int(12, "Reversal — Entry End Hour (GMT)", group=grp_sess, minval=8, maxval=19, tooltip="Reversals fire only during the morning London session.")
rev_end_m     = input.int(0,  "Reversal — Entry End Min  (GMT)", group=grp_sess)
monday_start  = input.int(6,  "Monday Start Hour (GMT)",         group=grp_sess)
japan_end_h   = input.int(6,  "Japan End Hour    (GMT)",         group=grp_sess, minval=1, maxval=8)

use_engulf    = input.bool(true, "Engulfing Candle",        group=grp_sig)
use_pin       = input.bool(true, "Pin Bar",                 group=grp_sig)
use_3bar      = input.bool(true, "3-Bar Reversal",          group=grp_sig)
pin_wick_mult = input.float(2.0, "Pin Bar — Min Wick:Body", group=grp_sig, minval=1.0, step=0.25)

ema_fast_len = input.int(20, "EMA Fast Length (1H & 4H)",  group=grp_htf, minval=5,  maxval=100, tooltip="EMA fast period for reversal bias on 1H and 4H timeframes.")
ema_slow_len = input.int(50, "EMA Slow Length (1H & 4H)",  group=grp_htf, minval=10, maxval=200, tooltip="EMA slow period for reversal bias on 1H and 4H timeframes.")

show_zone    = input.bool(true, "Show Zone Box",           group=grp_disp)
show_session = input.bool(true, "Show Session Background", group=grp_disp)

// ─── SESSION TIMING ──────────────────────────────────────────────────────────
h         = hour(time, "UTC")
m         = minute(time, "UTC")
is_mon    = dayofweek(time, "UTC") == dayofweek.monday
start_min = (is_mon ? monday_start : entry_start_h) * 60 + entry_start_m
curr_min  = h * 60 + m
end_min   = entry_end_h * 60 + entry_end_m
in_sess     = curr_min >= start_min and curr_min <= end_min
rev_end_min = rev_end_h * 60 + rev_end_m
in_rev_sess = curr_min >= start_min and curr_min <= rev_end_min
in_japan    = (h == 23 and m >= 45) or (h >= 0 and h < japan_end_h)
is_2345     = h == 23 and m == 45
london_open_bar = not in_japan and
     ((dayofweek(time,"UTC") != dayofweek.monday and curr_min == entry_start_h * 60 + entry_start_m) or
      (dayofweek(time,"UTC") == dayofweek.monday  and curr_min == monday_start  * 60 + entry_start_m))

// ─── DXY OPEN ZONE ───────────────────────────────────────────────────────────
var float zone_top      = na
var float zone_bottom   = na
var bool  zone_pristine = false   // display only (orange vs grey)
var bool  japan_bull    = false
var bool  attr_pristine = false   // set at London open; true if ≥ attr_min_gap from near edge
var bool  london_touched= false   // true once London price touches the near zone edge
var bool  attr_traded   = false   // blocks a second attraction trade on the same zone
var bool  zone_traded   = false   // set only by reversal; blocks further reversals

if is_2345
    bool  prior_is_line      = math.abs(close[1] - open[1]) * 10000 < 10
    float prior_candle_close = prior_is_line ? close[2] : close[1]
    float japan_open         = open
    float gap_size           = math.abs(prior_candle_close - japan_open) * 10000
    if gap_size >= zone_min_gap
        zone_top    := math.max(prior_candle_close, japan_open)
        zone_bottom := math.min(prior_candle_close, japan_open)
        japan_bull  := japan_open > prior_candle_close
    else
        zone_top    := math.max(japan_open, close)
        zone_bottom := math.min(japan_open, close)
        japan_bull  := close > japan_open
    zone_pristine  := true
    attr_pristine  := false
    london_touched := false
    attr_traded    := false
    zone_traded    := false

// ─── LONDON OPEN — set attr_pristine ────────────────────────────────────────
if london_open_bar and not na(zone_top)
    if not japan_bull
        attr_pristine := (zone_bottom - close) * 10000 >= attr_min_gap
    else
        attr_pristine := (close - zone_top) * 10000 >= attr_min_gap
    london_touched := false

// ─── ZONE PRISTINE (display tracking) ────────────────────────────────────────
if not na(zone_top) and not is_2345
    if zone_pristine
        if japan_bull
            if close < zone_bottom
                zone_pristine := false
        else
            if close > zone_top
                zone_pristine := false

// ─── LONDON TOUCHED (ATTR/REV separator) ─────────────────────────────────────
// Updated BEFORE signal checks so the first touch bar can fire REV immediately.
bool prev_london_touched = london_touched
if not in_japan and not london_touched and not na(zone_top)
    if (not japan_bull and high >= zone_bottom) or (japan_bull and low <= zone_top)
        london_touched := true

// ─── 1H / 4H EMA BIAS (reversal gate) ────────────────────────────────────────
_1h_ema_fast = request.security(syminfo.tickerid, "60",  ta.ema(close, ema_fast_len), lookahead=barmerge.lookahead_off)
_1h_ema_slow = request.security(syminfo.tickerid, "60",  ta.ema(close, ema_slow_len), lookahead=barmerge.lookahead_off)
_4h_ema_fast = request.security(syminfo.tickerid, "240", ta.ema(close, ema_fast_len), lookahead=barmerge.lookahead_off)
_4h_ema_slow = request.security(syminfo.tickerid, "240", ta.ema(close, ema_slow_len), lookahead=barmerge.lookahead_off)

rev_bias_bull = _1h_ema_fast > _1h_ema_slow and _4h_ema_fast > _4h_ema_slow
rev_bias_bear = _1h_ema_fast < _1h_ema_slow and _4h_ema_fast < _4h_ema_slow

// ─── CANDLE MEASUREMENTS ─────────────────────────────────────────────────────
body_sz    = math.abs(close - open)
upper_wick = high - math.max(open, close)
lower_wick = math.min(open, close) - low
cndl_range = high - low
is_bull    = close > open
is_bear    = close < open
rev_candle_ok = (body_sz * 10000 >= rev_min_body) and (cndl_range * 10000 >= rev_min_range)

// ─── ENTRY SIGNALS ───────────────────────────────────────────────────────────
bull_engulf = use_engulf and is_bull and not is_bull[1] and close > open[1] and open < close[1] and body_sz >= body_sz[1] * 0.8
bear_engulf = use_engulf and is_bear and not is_bear[1] and close < open[1] and open > close[1] and body_sz >= body_sz[1] * 0.8
bull_pin    = use_pin and lower_wick >= body_sz * pin_wick_mult and upper_wick <= body_sz * 1.5 and cndl_range > 0
bear_pin    = use_pin and upper_wick >= body_sz * pin_wick_mult and lower_wick <= body_sz * 1.5 and cndl_range > 0
bar2_range  = math.abs(close[2] - open[2])
indecision  = body_sz[1] <= bar2_range * 0.5
bull_3bar   = use_3bar and close[2] < open[2] and indecision and is_bull and close > open[2]
bear_3bar   = use_3bar and close[2] > open[2] and indecision and is_bear and close < open[2]
bull_sig    = bull_engulf or bull_pin or bull_3bar
bear_sig    = bear_engulf or bear_pin or bear_3bar

// ─── IMPULSIVE APPROACH (3-bar net move toward zone) ─────────────────────────
approach_pts_long  = (close - close[3]) * 10000   // positive = moved up toward zone_top
approach_pts_short = (close[3] - close) * 10000   // positive = moved down toward zone_bottom
impulsive_long  = not japan_bull and approach_pts_long  >= attr_approach
impulsive_short = japan_bull      and approach_pts_short >= attr_approach

// ─── ZONE WIDTH ───────────────────────────────────────────────────────────────
zone_width_pts = not na(zone_top) ? (zone_top - zone_bottom) * 10000 : 0.0

// ─── DISTANCES ───────────────────────────────────────────────────────────────
dist_to_bottom = (close - zone_bottom) * 10000
dist_to_top    = (zone_top - close)    * 10000
dist_rev_long  = math.abs(close - zone_bottom) * 10000
dist_rev_short = math.abs(zone_top - close)    * 10000

// ─── STRATEGY ENTRIES ────────────────────────────────────────────────────────
// Attraction: fires while zone NOT yet touched. attr_traded blocks a second ATTR.
// Reversal  : fires once zone IS touched. zone_traded blocks further REV.
//   Both respect strategy.position_size == 0 (no stacked positions).
//
// TP / SL rules (all trades 1:1 RR):
//   Attraction Long  : TP = zone_bottom + near_buffer (near edge + 50 pts)
//                      SL = entry − (TP − entry)  [1:1 mirror]
//   Attraction Short : TP = zone_top − near_buffer
//                      SL = entry + (entry − TP)  [1:1 mirror]
//   Reversal Long    : SL = structural pivot low below entry, TP = 1:1 above
//   Reversal Short   : SL = structural pivot high above entry, TP = 1:1 below

float attr_near_buf_f = attr_near_buf / 10000.0

// — ATTRACTION LONG ——————————————————————————————————————————————————————————
if in_window and strategy.position_size == 0 and not attr_traded
    if attr_enabled and attr_pristine and not london_touched and in_sess and not in_japan
        if not japan_bull and bull_sig and impulsive_long and zone_width_pts >= zone_min_width
            float tp_price  = zone_bottom + attr_near_buf_f
            float sl_dist   = tp_price - close
            float sl_price  = close - sl_dist
            float reward    = (tp_price - close) * 10000
            if sl_dist > 0 and reward >= attr_min_reward
                strategy.entry("Attr Long", strategy.long)
                strategy.exit("AL Exit", "Attr Long", limit=tp_price, stop=sl_price)
                label.new(bar_index, low - cndl_range, "▲ ATTR LONG",
                    color=color.new(color.green, 10), textcolor=color.white,
                    style=label.style_label_up, size=size.small)
                attr_traded := true

// — ATTRACTION SHORT ——————————————————————————————————————————————————————————
if in_window and strategy.position_size == 0 and not attr_traded
    if attr_enabled and attr_pristine and not london_touched and in_sess and not in_japan
        if japan_bull and bear_sig and impulsive_short and zone_width_pts >= zone_min_width
            float tp_price  = zone_top - attr_near_buf_f
            float sl_dist   = close - tp_price
            float sl_price  = close + sl_dist
            float reward    = (close - tp_price) * 10000
            if sl_dist > 0 and reward >= attr_min_reward
                strategy.entry("Attr Short", strategy.short)
                strategy.exit("AS Exit", "Attr Short", limit=tp_price, stop=sl_price)
                label.new(bar_index, high + cndl_range, "▼ ATTR SHORT",
                    color=color.new(color.red, 10), textcolor=color.white,
                    style=label.style_label_down, size=size.small)
                attr_traded := true

// — REVERSAL LONG ─────────────────────────────────────────────────────────────
if in_window and strategy.position_size == 0 and not zone_traded
    if rev_enabled and london_touched and in_rev_sess and not in_japan
        if bull_sig and rev_bias_bull and dist_rev_long <= rev_max_dist and rev_candle_ok
            float sl_price  = zone_bottom
            float sl_dist   = close - sl_price
            if sl_dist > 0
                float tp_price = close + sl_dist
                strategy.entry("Rev Long", strategy.long)
                strategy.exit("RL Exit", "Rev Long", limit=tp_price, stop=sl_price)
                label.new(bar_index, low - cndl_range, "▲ REV LONG",
                    color=color.new(color.teal, 10), textcolor=color.white,
                    style=label.style_label_up, size=size.small)
                zone_traded := true

// — REVERSAL SHORT ────────────────────────────────────────────────────────────
if in_window and strategy.position_size == 0 and not zone_traded
    if rev_enabled and london_touched and in_rev_sess and not in_japan
        if bear_sig and rev_bias_bear and dist_rev_short <= rev_max_dist and rev_candle_ok
            float sl_price  = zone_top
            float sl_dist   = sl_price - close
            if sl_dist > 0
                float tp_price = close - sl_dist
                strategy.entry("Rev Short", strategy.short)
                strategy.exit("RS Exit", "Rev Short", limit=tp_price, stop=sl_price)
                label.new(bar_index, high + cndl_range, "▼ REV SHORT",
                    color=color.new(color.purple, 10), textcolor=color.white,
                    style=label.style_label_down, size=size.small)
                zone_traded := true

// ─── VISUALS ─────────────────────────────────────────────────────────────────
zone_edge_col = zone_pristine ? color.new(color.orange, 20) : color.new(color.gray, 40)
zone_fill_col = zone_pristine ? color.new(color.orange, 80) : color.new(color.gray, 85)
p_top = plot(show_zone and not na(zone_top)    ? zone_top    : na, "Zone Top",    color=zone_edge_col, linewidth=2)
p_bot = plot(show_zone and not na(zone_bottom) ? zone_bottom : na, "Zone Bottom", color=zone_edge_col, linewidth=2)
fill(p_top, p_bot, color=zone_fill_col, title="Zone Fill")
bgcolor(show_session and in_sess ? color.new(color.blue, 93) : na, title="Session")
