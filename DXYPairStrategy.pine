//@version=6
// ─────────────────────────────────────────────────────────────────────────────
// DXY Pair Strategy  v2.0
// Apply to any of the 8 DXY-correlated pairs on a 15m chart.
// All zone detection, signal logic and SL/TP sizing source from TVC:DXY 15m.
// Trade entries and exits are placed on the current pair's price.
//
// Pair Configuration quick-reference:
//   EURUSD / GBPUSD / AUDUSD / NZDUSD  →  Dir: -1   Factor: 0.01
//   USDCAD / USDCHF                    →  Dir: +1   Factor: 0.01
//   USDJPY                             →  Dir: +1   Factor: 1.0
//   XAUUSD                             →  Dir: -1   Factor: 100.0
//
// Architecture note:
//   DXY 15m OHLC is pulled via request.security() and the zone/signal logic
//   runs in the pair chart's script context using those DXY price series.
//   This avoids nested request.security() calls (not permitted in Pine Script).
//   The 1H and 4H EMA bias gates are pulled from DXY via separate calls.
// ─────────────────────────────────────────────────────────────────────────────
strategy("DXY Pair Strategy",
    shorttitle            = "DXY Pair",
    overlay               = true,
    initial_capital       = 100000,
    default_qty_type      = strategy.fixed,
    default_qty_value     = 1,
    process_orders_on_close = true,
    calc_on_every_tick    = false,
    max_labels_count      = 500,
    commission_type       = strategy.commission.percent,
    commission_value      = 0)

// ─── BACKTEST PERIOD ─────────────────────────────────────────────────────────
grp_bt     = "Backtest Period"
start_date = input.time(timestamp("01 Jul 2025 00:00 +0000"), "Start Date", group=grp_bt)
end_date   = input.time(timestamp("30 Apr 2026 23:59 +0000"), "End Date",   group=grp_bt)
in_window  = time >= start_date and time <= end_date

// ─── PAIR CONFIGURATION ───────────────────────────────────────────────────────
grp_pair    = "Pair Configuration"
pair_dir    = input.int(-1, "Direction  (+1 = USD-base   /   -1 = USD-quote or Gold)",
    options=[-1, 1], group=grp_pair,
    tooltip="+1: trade same direction as DXY (USDJPY, USDCAD, USDCHF).\n-1: trade inverse to DXY (EURUSD, GBPUSD, AUDUSD, NZDUSD, XAUUSD).")
tick_factor = input.float(0.01, "Tick Conversion Factor", group=grp_pair, step=0.01,
    tooltip="Scales DXY SL/TP distance → pair price distance.\n5dp FX (EURUSD/GBPUSD/AUDUSD/NZDUSD/USDCAD/USDCHF): 0.01\nUSDJPY: 1.0\nXAUUSD: 100.0")

// ─── SIGNAL PARAMETERS ───────────────────────────────────────────────────────
grp_zone = "Signal Zones"
grp_sess = "Session Window (GMT)"
grp_sig  = "Entry Signals"
grp_htf  = "HTF Bias (Reversal Gate)"
grp_disp = "Display"

attr_enabled    = input.bool(true,  "Enable Attraction Trades",                    group=grp_zone)
attr_min_gap    = input.int( 150,   "Attraction — Min Gap at London Open (pts)",   group=grp_zone, minval=50,  step=25,  tooltip="At London open, DXY price must be at least this many pts from the near zone edge.")
attr_approach   = input.int( 150,   "Attraction — Min 3-Bar Approach (pts)",       group=grp_zone, minval=50,  step=25,  tooltip="3-bar net DXY move toward the zone must be at least this many pts.")
attr_min_reward = input.int( 150,   "Attraction — Min Reward to TP (pts)",         group=grp_zone, minval=50,  step=25,  tooltip="Minimum distance (pts) from DXY entry to TP.")
attr_near_buf   = input.int(  50,   "Attraction — Near-Edge TP Buffer (pts)",      group=grp_zone, minval=0,   step=10,  tooltip="TP set to near zone edge + this buffer. 50 pts = TP sits 50 pts inside zone.")
zone_min_gap    = input.int(  30,   "Zone — Min Gap (pts)",                        group=grp_zone, minval=5,   step=5)
zone_min_width  = input.int( 150,   "Zone — Min Width (pts)",                      group=grp_zone, minval=50,  step=25)
rev_enabled     = input.bool(true,  "Enable Reversal Trades",                      group=grp_zone)
rev_max_dist    = input.int( 500,   "Reversal — Max Distance from Zone (pts)",     group=grp_zone, minval=50,  step=50)
rev_min_body    = input.int( 200,   "Reversal — Min Candle Body (pts)",            group=grp_zone, minval=0,   step=25)
rev_min_range   = input.int( 400,   "Reversal — Min Candle Range (pts)",           group=grp_zone, minval=0,   step=25)

entry_start_h = input.int(7,  "Entry Start Hour (GMT)",          group=grp_sess)
entry_start_m = input.int(30, "Entry Start Min  (GMT)",          group=grp_sess)
entry_end_h   = input.int(19, "Entry End Hour   (GMT)",          group=grp_sess)
entry_end_m   = input.int(30, "Entry End Min    (GMT)",          group=grp_sess)
rev_end_h     = input.int(12, "Reversal — Entry End Hour (GMT)", group=grp_sess)
rev_end_m     = input.int(0,  "Reversal — Entry End Min  (GMT)", group=grp_sess)
monday_start  = input.int(6,  "Monday Start Hour (GMT)",         group=grp_sess)
japan_end_h   = input.int(6,  "Japan End Hour    (GMT)",         group=grp_sess)

use_engulf    = input.bool(true,  "Engulfing Candle",        group=grp_sig)
use_pin       = input.bool(true,  "Pin Bar",                 group=grp_sig)
use_3bar      = input.bool(true,  "3-Bar Reversal",          group=grp_sig)
pin_wick_mult = input.float(2.0,  "Pin Bar — Min Wick:Body", group=grp_sig, minval=1.0, step=0.25)

ema_fast_len = input.int(20, "EMA Fast Length (1H & 4H)", group=grp_htf, minval=5,  maxval=100)
ema_slow_len = input.int(50, "EMA Slow Length (1H & 4H)", group=grp_htf, minval=10, maxval=200)

show_zone    = input.bool(true, "Show DXY Zone Lines on Pair Chart", group=grp_disp)
show_session = input.bool(true, "Show Session Background",           group=grp_disp)

// ─── DXY DATA (15m OHLC + 1H/4H EMA bias) ────────────────────────────────────
dxy_o = request.security("TVC:DXY", "15", open,  lookahead=barmerge.lookahead_off)
dxy_h = request.security("TVC:DXY", "15", high,  lookahead=barmerge.lookahead_off)
dxy_l = request.security("TVC:DXY", "15", low,   lookahead=barmerge.lookahead_off)
dxy_c = request.security("TVC:DXY", "15", close, lookahead=barmerge.lookahead_off)

dxy_1h_ema_fast = request.security("TVC:DXY", "60",  ta.ema(close, ema_fast_len), lookahead=barmerge.lookahead_off)
dxy_1h_ema_slow = request.security("TVC:DXY", "60",  ta.ema(close, ema_slow_len), lookahead=barmerge.lookahead_off)
dxy_4h_ema_fast = request.security("TVC:DXY", "240", ta.ema(close, ema_fast_len), lookahead=barmerge.lookahead_off)
dxy_4h_ema_slow = request.security("TVC:DXY", "240", ta.ema(close, ema_slow_len), lookahead=barmerge.lookahead_off)

// ─── SESSION FLAGS ────────────────────────────────────────────────────────────
h_gmt   = hour(time, "UTC")
m_gmt   = minute(time, "UTC")
is_mon  = dayofweek(time, "UTC") == dayofweek.monday
s_min   = (is_mon ? monday_start : entry_start_h) * 60 + entry_start_m
c_min   = h_gmt * 60 + m_gmt
in_sess     = c_min >= s_min and c_min <= (entry_end_h * 60 + entry_end_m)
in_rev_sess = c_min >= s_min and c_min <= (rev_end_h   * 60 + rev_end_m)
in_japan    = (h_gmt == 23 and m_gmt >= 45) or (h_gmt >= 0 and h_gmt < japan_end_h)
is_2345     = h_gmt == 23 and m_gmt == 45
london_open_bar = not in_japan and
     ((dayofweek(time,"UTC") != dayofweek.monday and c_min == entry_start_h * 60 + entry_start_m) or
      (dayofweek(time,"UTC") == dayofweek.monday  and c_min == monday_start  * 60 + entry_start_m))

// ─── DXY OPEN ZONE ───────────────────────────────────────────────────────────
var float zone_top      = na
var float zone_bottom   = na
var bool  zone_pristine = false   // display only
var bool  japan_bull    = false
var bool  attr_pristine = false   // set at London open
var bool  london_touched= false   // true once London DXY touches near zone edge
var bool  attr_traded   = false   // blocks a second attraction trade
var bool  zone_traded   = false   // set only by reversal; blocks further REV

if is_2345
    bool  prior_line = math.abs(dxy_c[1] - dxy_o[1]) * 10000 < 10
    float prior_cl   = prior_line ? dxy_c[2] : dxy_c[1]
    float j_open     = dxy_o
    float gap        = math.abs(prior_cl - j_open) * 10000
    if gap >= zone_min_gap
        zone_top    := math.max(prior_cl, j_open)
        zone_bottom := math.min(prior_cl, j_open)
        japan_bull  := j_open > prior_cl
    else
        zone_top    := math.max(j_open, dxy_c)
        zone_bottom := math.min(j_open, dxy_c)
        japan_bull  := dxy_c > j_open
    zone_pristine  := true
    attr_pristine  := false
    london_touched := false
    attr_traded    := false
    zone_traded    := false

// ─── LONDON OPEN — set attr_pristine ─────────────────────────────────────────
if london_open_bar and not na(zone_top)
    if not japan_bull
        attr_pristine := (zone_bottom - dxy_c) * 10000 >= attr_min_gap
    else
        attr_pristine := (dxy_c - zone_top) * 10000 >= attr_min_gap
    london_touched := false

// ─── ZONE PRISTINE (display tracking) ────────────────────────────────────────
if not na(zone_top) and not is_2345
    if zone_pristine
        if japan_bull
            if dxy_c < zone_bottom
                zone_pristine := false
        else
            if dxy_c > zone_top
                zone_pristine := false

// ─── LONDON TOUCHED (ATTR/REV separator, based on DXY) ───────────────────────
if not in_japan and not london_touched and not na(zone_top)
    if (not japan_bull and dxy_h >= zone_bottom) or (japan_bull and dxy_l <= zone_top)
        london_touched := true

// ─── REV BIAS (DXY 1H + 4H EMA) ─────────────────────────────────────────────
rev_bias_bull = dxy_1h_ema_fast > dxy_1h_ema_slow and dxy_4h_ema_fast > dxy_4h_ema_slow
rev_bias_bear = dxy_1h_ema_fast < dxy_1h_ema_slow and dxy_4h_ema_fast < dxy_4h_ema_slow

// ─── DXY CANDLE MEASUREMENTS ─────────────────────────────────────────────────
dxy_bs   = math.abs(dxy_c - dxy_o)
dxy_uw   = dxy_h - math.max(dxy_o, dxy_c)
dxy_lw   = math.min(dxy_o, dxy_c) - dxy_l
dxy_cr   = dxy_h - dxy_l
dxy_bull = dxy_c > dxy_o
dxy_bear = dxy_c < dxy_o
dxy_bs1  = math.abs(dxy_c[1] - dxy_o[1])
rev_cndl_ok = (dxy_bs * 10000 >= rev_min_body) and (dxy_cr * 10000 >= rev_min_range)

// ─── DXY ENTRY SIGNALS ───────────────────────────────────────────────────────
bull_eng = use_engulf and dxy_bull and not (dxy_c[1] > dxy_o[1]) and dxy_c > dxy_o[1] and dxy_o < dxy_c[1] and dxy_bs >= dxy_bs1 * 0.8
bear_eng = use_engulf and dxy_bear and not (dxy_c[1] < dxy_o[1]) and dxy_c < dxy_o[1] and dxy_o > dxy_c[1] and dxy_bs >= dxy_bs1 * 0.8
bull_pin = use_pin and dxy_lw >= dxy_bs * pin_wick_mult and dxy_uw <= dxy_bs * 1.5 and dxy_cr > 0
bear_pin = use_pin and dxy_uw >= dxy_bs * pin_wick_mult and dxy_lw <= dxy_bs * 1.5 and dxy_cr > 0
dxy_b2r  = math.abs(dxy_c[2] - dxy_o[2])
dxy_ind  = dxy_bs1 <= dxy_b2r * 0.5
bull_3b  = use_3bar and dxy_c[2] < dxy_o[2] and dxy_ind and dxy_bull and dxy_c > dxy_o[2]
bear_3b  = use_3bar and dxy_c[2] > dxy_o[2] and dxy_ind and dxy_bear and dxy_c < dxy_o[2]
dxy_bull_sig = bull_eng or bull_pin or bull_3b
dxy_bear_sig = bear_eng or bear_pin or bear_3b

// ─── IMPULSIVE APPROACH (3-bar DXY move toward zone) ─────────────────────────
approach_l = (dxy_c - dxy_c[3]) * 10000   // positive = moved up toward zone_top
approach_s = (dxy_c[3] - dxy_c) * 10000   // positive = moved down toward zone_bottom
impulsive_l = not japan_bull and approach_l >= attr_approach
impulsive_s = japan_bull      and approach_s >= attr_approach

// ─── ZONE WIDTH ───────────────────────────────────────────────────────────────
zone_w_pts = not na(zone_top) ? (zone_top - zone_bottom) * 10000 : 0.0

// ─── DXY DISTANCES ───────────────────────────────────────────────────────────
d_rv_l = math.abs(dxy_c - zone_bottom) * 10000
d_rv_s = math.abs(zone_top - dxy_c)    * 10000

// ─── ENTRIES ─────────────────────────────────────────────────────────────────
// SL/TP computed on DXY scale, then multiplied by tick_factor to get pair distance.
// trade_dir = dxy_direction × pair_dir → +1 long / -1 short on the pair.

float attr_near_buf_f = attr_near_buf / 10000.0
float cr_px           = high - low   // pair candle range for label offset

// — ATTRACTION LONG ——————————————————————————————————————————————————————————
if in_window and strategy.position_size == 0 and not attr_traded
    if attr_enabled and attr_pristine and not london_touched and in_sess and not in_japan
        if not japan_bull and dxy_bull_sig and impulsive_l and zone_w_pts >= zone_min_width
            float dxy_tp    = zone_bottom + attr_near_buf_f
            float dxy_sl_d  = dxy_tp - dxy_c           // 1:1 mirror
            float reward    = dxy_sl_d * 10000
            if dxy_sl_d > 0 and reward >= attr_min_reward
                float pair_dist = dxy_sl_d * tick_factor
                int   trade_dir = pair_dir              // +1 or -1
                if trade_dir == 1
                    strategy.entry("Attr Long", strategy.long)
                    strategy.exit("AL X", "Attr Long", limit=close + pair_dist, stop=close - pair_dist)
                    label.new(bar_index, low - cr_px, "▲ ATTR↑",
                        color=color.new(color.green, 10), textcolor=color.white,
                        style=label.style_label_up, size=size.small)
                else
                    strategy.entry("Attr Long", strategy.short)
                    strategy.exit("AL X", "Attr Long", limit=close - pair_dist, stop=close + pair_dist)
                    label.new(bar_index, high + cr_px, "▼ ATTR↑",
                        color=color.new(color.green, 10), textcolor=color.white,
                        style=label.style_label_down, size=size.small)
                attr_traded := true

// — ATTRACTION SHORT ——————————————————————————————————————————————————————————
if in_window and strategy.position_size == 0 and not attr_traded
    if attr_enabled and attr_pristine and not london_touched and in_sess and not in_japan
        if japan_bull and dxy_bear_sig and impulsive_s and zone_w_pts >= zone_min_width
            float dxy_tp    = zone_top - attr_near_buf_f
            float dxy_sl_d  = dxy_c - dxy_tp           // 1:1 mirror
            float reward    = dxy_sl_d * 10000
            if dxy_sl_d > 0 and reward >= attr_min_reward
                float pair_dist = dxy_sl_d * tick_factor
                int   trade_dir = -1 * pair_dir         // DXY short inverts direction
                if trade_dir == 1
                    strategy.entry("Attr Short", strategy.long)
                    strategy.exit("AS X", "Attr Short", limit=close + pair_dist, stop=close - pair_dist)
                    label.new(bar_index, low - cr_px, "▲ ATTR↓",
                        color=color.new(color.red, 10), textcolor=color.white,
                        style=label.style_label_up, size=size.small)
                else
                    strategy.entry("Attr Short", strategy.short)
                    strategy.exit("AS X", "Attr Short", limit=close - pair_dist, stop=close + pair_dist)
                    label.new(bar_index, high + cr_px, "▼ ATTR↓",
                        color=color.new(color.red, 10), textcolor=color.white,
                        style=label.style_label_down, size=size.small)
                attr_traded := true

// — REVERSAL LONG (DXY bouncing up from zone support) ─────────────────────────
if in_window and strategy.position_size == 0 and not zone_traded
    if rev_enabled and london_touched and in_rev_sess and not in_japan
        if dxy_bull_sig and rev_bias_bull and d_rv_l <= rev_max_dist and rev_cndl_ok
            float dxy_sl_d  = dxy_c - zone_bottom
            if dxy_sl_d > 0
                float pair_dist = dxy_sl_d * tick_factor
                int   trade_dir = pair_dir
                if trade_dir == 1
                    strategy.entry("Rev Long", strategy.long)
                    strategy.exit("RL X", "Rev Long", limit=close + pair_dist, stop=close - pair_dist)
                    label.new(bar_index, low - cr_px, "▲ REV↑",
                        color=color.new(color.teal, 10), textcolor=color.white,
                        style=label.style_label_up, size=size.small)
                else
                    strategy.entry("Rev Long", strategy.short)
                    strategy.exit("RL X", "Rev Long", limit=close - pair_dist, stop=close + pair_dist)
                    label.new(bar_index, high + cr_px, "▼ REV↑",
                        color=color.new(color.teal, 10), textcolor=color.white,
                        style=label.style_label_down, size=size.small)
                zone_traded := true

// — REVERSAL SHORT (DXY rejecting down from zone resistance) ──────────────────
if in_window and strategy.position_size == 0 and not zone_traded
    if rev_enabled and london_touched and in_rev_sess and not in_japan
        if dxy_bear_sig and rev_bias_bear and d_rv_s <= rev_max_dist and rev_cndl_ok
            float dxy_sl_d  = zone_top - dxy_c
            if dxy_sl_d > 0
                float pair_dist = dxy_sl_d * tick_factor
                int   trade_dir = -1 * pair_dir
                if trade_dir == 1
                    strategy.entry("Rev Short", strategy.long)
                    strategy.exit("RS X", "Rev Short", limit=close + pair_dist, stop=close - pair_dist)
                    label.new(bar_index, low - cr_px, "▲ REV↓",
                        color=color.new(color.purple, 10), textcolor=color.white,
                        style=label.style_label_up, size=size.small)
                else
                    strategy.entry("Rev Short", strategy.short)
                    strategy.exit("RS X", "Rev Short", limit=close - pair_dist, stop=close + pair_dist)
                    label.new(bar_index, high + cr_px, "▼ REV↓",
                        color=color.new(color.purple, 10), textcolor=color.white,
                        style=label.style_label_down, size=size.small)
                zone_traded := true

// ─── VISUALS ─────────────────────────────────────────────────────────────────
zone_col_edge = zone_pristine ? color.new(color.orange, 20) : color.new(color.gray, 40)
zone_col_fill = zone_pristine ? color.new(color.orange, 80) : color.new(color.gray, 85)
p_top_line = plot(show_zone and not na(zone_top)    ? zone_top    : na, "DXY Zone Top",    color=zone_col_edge, linewidth=1, style=plot.style_stepline)
p_bot_line = plot(show_zone and not na(zone_bottom) ? zone_bottom : na, "DXY Zone Bottom", color=zone_col_edge, linewidth=1, style=plot.style_stepline)
fill(p_top_line, p_bot_line, color=zone_col_fill, title="DXY Zone Fill")
bgcolor(show_session and in_sess ? color.new(color.blue, 93) : na, title="London Session")
