//@version=6
// ─────────────────────────────────────────────────────────────────────────────
// DXY Pair Strategy  v3.0
// Apply to any of the 8 DXY-correlated pairs on a 15m chart.
// All zone detection, signal logic and SL/TP sizing source from TVC:DXY 15m.
// Trade entries and exits are placed on the current pair's price.
//
// TRADE LOGIC (mirrors DXYZoneStrategy / DXYTradeAlert):
//   REV  : DXY moves away from London session opening level, returns to it,
//          confirmation candle fires, 1H DXY BB expanding in trade direction.
//          SL = prior DXY calendar day high/low ± buffer, capped at max_sl_pts.
//          SL distance converted to pair price via tick_factor.
//
// NOTE: Attraction (pristine gap) trades are intentionally excluded — managed manually.
//       GAP_REJ only fires after the zone has been touched (attr_gap_touched = true).
//
// PAIR CONFIGURATION:
//   EURUSD / GBPUSD / AUDUSD / NZDUSD  →  Dir: -1   Factor: 0.01
//   USDCAD / USDCHF                    →  Dir: +1   Factor: 0.01
//   USDJPY                             →  Dir: +1   Factor: 1.0
//   XAUUSD                             →  Dir: -1   Factor: 100.0
//
// ARCHITECTURE:
//   DXY 15m OHLC is pulled via request.security(). Session state (london_open_price,
//   pd_high/pd_low, max_move) is tracked using pair chart time (UTC), which aligns
//   with DXY 15m timestamps. BB regime is pulled from DXY 1H and 4H directly.
// ─────────────────────────────────────────────────────────────────────────────
strategy("DXY Pair Strategy",
    shorttitle            = "DXY Pair",
    overlay               = true,
    initial_capital       = 100000,
    default_qty_type      = strategy.fixed,
    default_qty_value     = 1,
    process_orders_on_close = true,
    calc_on_every_tick    = false,
    max_labels_count      = 500,
    commission_type       = strategy.commission.percent,
    commission_value      = 0)

// ─── BACKTEST PERIOD ─────────────────────────────────────────────────────────
grp_bt     = "Backtest Period"
start_date = input.time(timestamp("01 Aug 2023 00:00 +0000"), "Start Date", group=grp_bt)
end_date   = input.time(timestamp("30 Apr 2026 23:59 +0000"), "End Date",   group=grp_bt)
in_window  = time >= start_date and time <= end_date

// ─── PAIR AUTO-DETECTION ─────────────────────────────────────────────────────
// Direction and tick factor are set automatically from the chart symbol.
// Switch freely between EURUSD / GBPUSD / AUDUSD / NZDUSD / USDCAD / USDCHF / USDJPY / XAUUSD
// — no manual reconfiguration needed.
string _sym = syminfo.ticker

// pair_dir: +1 = USD is base (USDJPY, USDCAD, USDCHF) — trades same direction as DXY
//           -1 = USD is quote or Gold (EURUSD, GBPUSD, AUDUSD, NZDUSD, XAUUSD) — inverse DXY
bool   _usd_base   = str.contains(_sym, "USDJPY") or str.contains(_sym, "USDCAD") or str.contains(_sym, "USDCHF")
int    pair_dir    = _usd_base ? 1 : -1

// tick_factor: scales DXY pts → approximate pair price movement
//   USDJPY: 1.0 | XAUUSD: 100.0 | all 5dp FX pairs (EURUSD/GBPUSD/AUDUSD/NZDUSD/USDCAD/USDCHF): 0.01
float  tick_factor = str.contains(_sym, "USDJPY") ? 1.0 :
                     str.contains(_sym, "XAUUSD") ? 100.0 : 0.01

// ATTR CORE direction: XAUUSD = LONG only (DXY long → Gold short, 66.7% WR)
//                      all other pairs = SHORT only (DXY short setup, 68.6% WR)
string attr_core_dir = str.contains(_sym, "XAUUSD") ? "LONG only" : "SHORT only"

// ─── SIGNAL PARAMETERS ───────────────────────────────────────────────────────
grp_zone = "Signal Parameters"
grp_sess = "Session Window (GMT)"
grp_sig  = "Entry Signals"
grp_htf  = "HTF Bias (BB Regime)"
grp_disp = "Display"

// London Open Attraction (LON_ATTR)
lon_attr_enabled   = input.bool(true,  "Enable London Open Attraction (LON_ATTR — LONG only)", group=grp_zone, tooltip="Pin bar attraction trade toward the DXY London session open level. LONG only: DXY price >= min pts below DXY open, zone pristine, bull pin bar, 4H BB flat. SHORT direction dropped — HTF analysis shows SHORT trades are negative across all regimes.")
lon_attr_min_long  = input.int(1000,   "LON_ATTR — Min Distance Long (pts below DXY open)",  group=grp_zone, minval=50, step=10,  tooltip="Long fires when DXY close is at least this many pts below London open. 4H BB must be flat. HTF analysis: 4H flat gives +25.1R vs -22.2R counter-trend over 32 months. Best WR threshold: 1725 pts (62.4% WR, +47.9R pair net R).")

// Attraction / Gap Rejection
attr_enabled        = input.bool(true,  "Enable Gap Rejection Trades",                       group=grp_zone)
attr_min_gap        = input.int(75,     "Attraction — Min Gap at Tokyo Open (pts)",           group=grp_zone, minval=10,  step=25,  tooltip="Gap between DXY 23:15 UTC close (candle prior to 23:30 phantom) and the 23:45 Tokyo open. Fallback: body of 23:45 candle. Backtest optimum: 75 pts (+77.9R pair net R at 25 pts vs +51.1R at 150 pts; 75 pts balances signal count with meaningful gap size).")
attr_min_reward     = input.int(100,    "Attraction — Min Reward to TP (pts)",                group=grp_zone, minval=50,  step=25)
attr_near_buf       = input.int(50,     "Attraction — Near-Edge TP Buffer (pts)",             group=grp_zone, minval=0,   step=10,  tooltip="TP = DXY London open ± this buffer. Converted to pair price via tick_factor.")
attr_use_near_tp    = input.bool(true,  "Attraction — Use Near-Edge TP (vs full gap fill)",   group=grp_zone)
attr_max_prev_range = input.int(8000,   "Attraction — Max Prior Session Range (pts)",         group=grp_zone, minval=500, step=500, tooltip="Skip attraction if prior DXY session range exceeded this. Median DXY daily range ~4800 pts; 8000 passes ~85% of days.")

// ATTR CORE (Pristine Zone Approach)
attr_core_enabled  = input.bool(true, "Enable ATTR CORE (Pristine Zone Approach)", group=grp_zone,
    tooltip="Fires when DXY approaches the Tokyo gap zone for the first time from outside — zone not yet touched. CORE filter: gap at London open < 1500 pts AND wave extension < 1500 pts. 32-month backtest: 70% WR, +65R across 6 pairs. Direction (LONG only / SHORT only) is auto-set from the chart symbol — XAUUSD = LONG only, all others = SHORT only.")
core_gap_max       = input.int(1500, "ATTR CORE — Max Gap at London Open (pts)", group=grp_zone, minval=200, step=100,
    tooltip="Maximum DXY distance (pts) from zone near edge at London open. CORE threshold: 1500 pts.")
core_wave_max      = input.int(1500, "ATTR CORE — Max Wave Extension (pts)", group=grp_zone, minval=100, step=100,
    tooltip="Maximum DXY wave extension (pts) away from zone after London open. CORE threshold: 1500 pts.")
attr_approach_min  = input.int(150, "ATTR CORE — Min 3-bar Approach (pts)", group=grp_zone, minval=50, step=25,
    tooltip="Minimum DXY move toward the zone over the last 3 bars (pts). Default: 150 pts.")

// Reversal
rev_enabled    = input.bool(true, "Enable Reversal Trades",                                   group=grp_zone)
rev_proximity  = input.int(250,   "Reversal — Max Distance from Opening Level (pts)",         group=grp_zone, minval=25,  step=25,  tooltip="Entry fires when DXY is within this many pts of the London session opening price. Backtest optimum: 250 pts (+69.4R pair net R, 56.8% WR). Captures early approach entries while DXY moves toward the opening level.")
rev_min_move   = input.int(400,   "Reversal — Min Move Away from Opening (pts)",              group=grp_zone, minval=25,  step=25,  tooltip="DXY must have moved at least this many pts from the London open before a reversal is valid. Backtest optimum: 400 pts (68.2% WR, +55.9R pair net R vs 54.9% at 100 pts). Larger prior move = genuine reversal, not noise.")
struct_sl_buf  = input.int(50,    "Reversal — Structural SL Buffer (pts)",                    group=grp_zone, minval=0,   step=10)
max_sl_pts     = input.int(3000,  "Reversal — Max SL Distance (pts)",                         group=grp_zone, minval=500, step=250)

// Session
entry_start_h = input.int(7,  "REV Entry Start Hour (GMT)",         group=grp_sess, minval=0, maxval=23, tooltip="London open — start of REV entry window. 07:00 GMT on Tue-Fri.")
entry_start_m = input.int(0,  "REV Entry Start Minute (GMT)",       group=grp_sess, minval=0, maxval=59)
attr_start_h  = input.int(6,  "ATTR Entry Start Hour (GMT)",        group=grp_sess, minval=0, maxval=23, tooltip="ATTR entry window opens 1 hour before London on Tue-Fri (Ash's rule: 06:00 GMT). Monday uses the Monday start time.")
attr_start_m  = input.int(0,  "ATTR Entry Start Minute (GMT)",      group=grp_sess, minval=0, maxval=59)
entry_end_h   = input.int(19, "Entry End Hour (GMT)",               group=grp_sess, minval=0, maxval=23)
entry_end_m   = input.int(30, "Entry End Minute (GMT)",             group=grp_sess, minval=0, maxval=59)
rev_end_h     = input.int(12, "Reversal — Entry End Hour (GMT)",    group=grp_sess, minval=6, maxval=19)
rev_end_m     = input.int(0,  "Reversal — Entry End Min (GMT)",     group=grp_sess, minval=0, maxval=59)
monday_start  = input.int(6,  "Monday Start Hour (GMT)",            group=grp_sess, minval=0, maxval=23, tooltip="Monday session starts at 06:30 GMT.")
japan_end_h   = input.int(6,  "Japan Session End Hour (GMT)",       group=grp_sess, minval=1, maxval=8)
lon_attr_end_h= input.int(18, "LON_ATTR — Entry End Hour (GMT)",    group=grp_sess, minval=7, maxval=22, tooltip="LON_ATTR entries close at this hour UTC. Default 18:00 — after this, London open reversals are less reliable.")

// Candle patterns (evaluated on DXY)
use_engulf    = input.bool(true,  "Engulfing Candle",                group=grp_sig)
use_pin       = input.bool(true,  "Pin Bar (directional)",           group=grp_sig, tooltip="Bullish pin (long lower wick) → LONG DXY entries only. Bearish pin (long upper wick) → SHORT DXY entries only.")
use_3bar      = input.bool(true,  "3-Bar Reversal",                  group=grp_sig)
pin_wick_mult = input.float(2.0,  "Pin Bar — Min Wick:Body",         group=grp_sig, minval=1.0, step=0.25)

// HTF BB Regime (DXY)
bb_period     = input.int(20,    "BB Period",                        group=grp_htf, minval=5,  maxval=50)
bb_std_mult   = input.float(2.0, "BB Std Dev Multiplier",           group=grp_htf, minval=0.5, step=0.25)
bb_lookback   = input.int(20,    "BB Width Lookback (flat detection)", group=grp_htf, minval=5, maxval=50)

// Display
show_session  = input.bool(true, "Show London Session Background",   group=grp_disp)
show_dxy_lvl  = input.bool(true, "Show DXY Opening Level on Chart",  group=grp_disp, tooltip="Plots DXY London open price on the pair chart for visual reference.")

// ─── DXY 15m OHLC ────────────────────────────────────────────────────────────
dxy_o = request.security("TVC:DXY", "15", open,  lookahead=barmerge.lookahead_off)
dxy_h = request.security("TVC:DXY", "15", high,  lookahead=barmerge.lookahead_off)
dxy_l = request.security("TVC:DXY", "15", low,   lookahead=barmerge.lookahead_off)
dxy_c = request.security("TVC:DXY", "15", close, lookahead=barmerge.lookahead_off)

// ─── SESSION FLAGS (pair chart time, aligns with DXY 15m) ────────────────────
h_gmt       = hour(time, "UTC")
m_gmt       = minute(time, "UTC")
is_mon      = dayofweek(time, "UTC") == dayofweek.monday
mon_min     = monday_start * 60 + 30
c_min       = h_gmt * 60 + m_gmt
e_min       = entry_end_h * 60 + entry_end_m
r_end_min   = rev_end_h   * 60 + rev_end_m
rev_s_min   = is_mon ? mon_min : entry_start_h * 60 + entry_start_m
attr_s_min  = is_mon ? mon_min : attr_start_h  * 60 + attr_start_m
in_sess          = c_min >= attr_s_min and c_min <= e_min
in_rev_sess      = c_min >= rev_s_min  and c_min <= r_end_min
in_japan         = (h_gmt == 23 and m_gmt >= 45) or (h_gmt >= 0 and h_gmt < japan_end_h)
lon_attr_end_min = lon_attr_end_h * 60
in_lon_attr_sess = c_min > rev_s_min and c_min <= lon_attr_end_min   // strictly after London open

is_london_open_bar = not in_japan and
     ((not is_mon and c_min == entry_start_h * 60 + entry_start_m) or
      (is_mon      and c_min == monday_start  * 60 + 30))

bool is_new_day = not na(time) and ta.change(dayofmonth(time, "UTC")) != 0

// ─── DXY PRIOR DAY HIGH / LOW (structural SL reference) ─────────────────────
var float dxy_today_high = na
var float dxy_today_low  = na
var float dxy_pd_high    = na
var float dxy_pd_low     = na
var float dxy_pd_range   = 0.0

if is_new_day
    if not na(dxy_today_high)
        dxy_pd_high  := dxy_today_high
        dxy_pd_low   := dxy_today_low
        dxy_pd_range := (dxy_today_high - dxy_today_low) * 10000
    dxy_today_high := dxy_h
    dxy_today_low  := dxy_l
else
    dxy_today_high := na(dxy_today_high) ? dxy_h : math.max(dxy_today_high, dxy_h)
    dxy_today_low  := na(dxy_today_low)  ? dxy_l : math.min(dxy_today_low,  dxy_l)

// ─── DXY LONDON OPEN LEVEL ───────────────────────────────────────────────────
var float dxy_london_open   = na
var float dxy_max_move_up   = 0.0
var float dxy_max_move_down = 0.0
var bool  lon_attr_traded   = false   // one LON_ATTR signal per session
// LON_ATTR pristine zone — body of the first DXY London session candle
var float dxy_lon_zone_top   = na    // body top  = math.max(dxy_o, dxy_c) of London open bar
var float dxy_lon_zone_bot   = na    // body bot  = math.min(dxy_o, dxy_c) of London open bar
var bool  dxy_pristine_long  = true  // false once any DXY candle open/close >= zone top (kills LONG setup)

if is_london_open_bar
    dxy_london_open    := dxy_o
    dxy_max_move_up    := 0.0
    dxy_max_move_down  := 0.0
    lon_attr_traded    := false
    dxy_lon_zone_top   := math.max(dxy_o, dxy_c)
    dxy_lon_zone_bot   := math.min(dxy_o, dxy_c)
    dxy_pristine_long  := true

// ─── DXY TOKYO OPEN ATTR GAP (23:45 UTC) ─────────────────────────────────────
// Gap = DXY 23:45 open vs DXY 23:15 close (prior to 23:30 phantom candle).
// Fallback: body of DXY 23:45 candle.
bool is_tokyo_open = h_gmt == 23 and m_gmt == 45

var float dxy_attr_target     = na
var float dxy_attr_gap_pts    = 0.0
var float dxy_attr_tokyo_open = na   // DXY 23:45 open = zone near edge (ATTR CORE)
var bool  attr_traded         = false
var bool  attr_gap_touched    = false  // latches true once price crosses the gap target this session
var float dxy_lon_open_close  = na   // DXY close at London open bar (ATTR CORE reference)
var float dxy_gap_at_lon      = 0.0  // gap from zone near edge to DXY close at London open (pts)

if is_tokyo_open
    dxy_attr_tokyo_open := dxy_o                  // ATTR CORE: zone near edge
    float raw_gap = (dxy_o - dxy_c[2]) * 10000   // 23:45 open vs 23:15 close
    if math.abs(raw_gap) >= 10
        dxy_attr_gap_pts := raw_gap
        dxy_attr_target  := dxy_c[2]
    else
        dxy_attr_gap_pts := (dxy_c - dxy_o) * 10000
        dxy_attr_target  := dxy_o
    attr_traded         := false
    attr_gap_touched    := false                  // zone is fresh/pristine at Tokyo open
    dxy_lon_open_close  := na                     // ATTR CORE: reset London open capture
    dxy_gap_at_lon      := 0.0                    // ATTR CORE: reset gap-at-London measure

// Latch: once the gap target is reached, zone is permanently filled for this session
if not na(dxy_attr_target)
    if dxy_attr_gap_pts < 0 and dxy_c >= dxy_attr_target
        attr_gap_touched := true
    else if dxy_attr_gap_pts > 0 and dxy_c <= dxy_attr_target
        attr_gap_touched := true

// ATTR CORE: capture DXY close at London open for gap/wave filter
if is_london_open_bar and not na(dxy_attr_target) and not attr_gap_touched
    dxy_lon_open_close := dxy_c
    if dxy_attr_gap_pts < 0   // gap down: near edge = dxy_attr_tokyo_open (higher)
        dxy_gap_at_lon := math.max((dxy_attr_tokyo_open - dxy_c) * 10000, 0.0)
    else if dxy_attr_gap_pts > 0   // gap up: near edge = dxy_attr_tokyo_open (lower)
        dxy_gap_at_lon := math.max((dxy_c - dxy_attr_tokyo_open) * 10000, 0.0)

// ─── DXY EXIT TRACKING ────────────────────────────────────────────────────────
// Positions are closed when DXY crosses its TP or SL level (not pair price levels).
// This replicates the Python backtest DXY-exit approach and produces correct R outcomes.
var float dxy_tp_lvl     = na     // DXY price level: close pair at profit when crossed
var float dxy_sl_lvl     = na     // DXY price level: close pair at loss when crossed
var bool  dxy_trade_long = true   // true = DXY direction is LONG for this trade
var bool  dxy_exit_track = false  // true = position is open and tracking DXY exit
var int   dxy_entry_bar  = -1     // bar_index of last entry (prevents same-bar exit check)

if not na(dxy_london_open) and not in_japan
    float above = (dxy_c - dxy_london_open) * 10000
    if above > 0
        dxy_max_move_up   := math.max(dxy_max_move_up,    above)
    else if above < 0
        dxy_max_move_down := math.max(dxy_max_move_down, -above)

// LON_ATTR pristine zone violation tracking (DXY candles — LONG only)
if not in_japan and not is_london_open_bar and not na(dxy_lon_zone_top)
    if dxy_o >= dxy_lon_zone_top or dxy_c >= dxy_lon_zone_top
        dxy_pristine_long  := false   // zone top breached — LONG setup no longer valid

// ─── DXY HTF BB REGIME ────────────────────────────────────────────────────────
// +1 = DXY 1H/4H bands expanding, MA sloping up   → REV LONG on DXY
// -1 = DXY 1H/4H bands expanding, MA sloping down → REV SHORT on DXY
//  0 = flat / contracting                          → skip REV; ATTR allowed

// DXY 1H
dxy_1h_basis  = request.security("TVC:DXY", "60",  ta.sma(close, bb_period),                                            lookahead=barmerge.lookahead_off)
dxy_1h_basis3 = request.security("TVC:DXY", "60",  ta.sma(close, bb_period)[3],                                         lookahead=barmerge.lookahead_off)
dxy_1h_width  = request.security("TVC:DXY", "60",  ta.stdev(close, bb_period) * bb_std_mult * 2.0,                      lookahead=barmerge.lookahead_off)
dxy_1h_wavg   = request.security("TVC:DXY", "60",  ta.sma(ta.stdev(close, bb_period) * bb_std_mult * 2.0, bb_lookback), lookahead=barmerge.lookahead_off)
dxy_1h_exp    = dxy_1h_width > dxy_1h_wavg
dxy_1h_sup    = dxy_1h_basis > dxy_1h_basis3
dxy_bb_1h     = dxy_1h_exp ? (dxy_1h_sup ? 1 : -1) : 0

// DXY 4H
dxy_4h_basis  = request.security("TVC:DXY", "240", ta.sma(close, bb_period),                                            lookahead=barmerge.lookahead_off)
dxy_4h_basis3 = request.security("TVC:DXY", "240", ta.sma(close, bb_period)[3],                                         lookahead=barmerge.lookahead_off)
dxy_4h_width  = request.security("TVC:DXY", "240", ta.stdev(close, bb_period) * bb_std_mult * 2.0,                      lookahead=barmerge.lookahead_off)
dxy_4h_wavg   = request.security("TVC:DXY", "240", ta.sma(ta.stdev(close, bb_period) * bb_std_mult * 2.0, bb_lookback), lookahead=barmerge.lookahead_off)
dxy_4h_exp    = dxy_4h_width > dxy_4h_wavg
dxy_4h_sup    = dxy_4h_basis > dxy_4h_basis3
dxy_bb_4h     = dxy_4h_exp ? (dxy_4h_sup ? 1 : -1) : 0

// ─── DXY CANDLE MEASUREMENTS ─────────────────────────────────────────────────
dxy_bs   = math.abs(dxy_c - dxy_o)
dxy_btop = math.max(dxy_o, dxy_c)
dxy_bbot = math.min(dxy_o, dxy_c)
dxy_uw   = dxy_h - dxy_btop
dxy_lw   = dxy_bbot - dxy_l
dxy_cr   = dxy_h - dxy_l
dxy_bs1  = math.abs(dxy_c[1] - dxy_o[1])

// ─── DXY ENTRY SIGNALS (directional pin bars) ────────────────────────────────
// Bullish pin: long LOWER wick (price rejected lows) → LONG DXY entries only
// Bearish pin: long UPPER wick (price rejected highs) → SHORT DXY entries only
bull_eng = use_engulf and dxy_c > dxy_o and not (dxy_c[1] > dxy_o[1]) and dxy_c > dxy_o[1] and dxy_o < dxy_c[1] and dxy_bs >= dxy_bs1 * 0.8
bear_eng = use_engulf and dxy_c < dxy_o and not (dxy_c[1] < dxy_o[1]) and dxy_c < dxy_o[1] and dxy_o > dxy_c[1] and dxy_bs >= dxy_bs1 * 0.8
bull_pin = use_pin and dxy_lw >= dxy_bs * pin_wick_mult and dxy_lw >= dxy_uw * 1.5 and dxy_cr > 0
bear_pin = use_pin and dxy_uw >= dxy_bs * pin_wick_mult and dxy_uw >= dxy_lw * 1.5 and dxy_cr > 0
dxy_b2r  = math.abs(dxy_c[2] - dxy_o[2])
dxy_ind  = dxy_bs1 <= dxy_b2r * 0.5
bull_3b  = use_3bar and dxy_c[2] < dxy_o[2] and dxy_ind and dxy_c > dxy_o and dxy_c > dxy_o[2]
bear_3b  = use_3bar and dxy_c[2] > dxy_o[2] and dxy_ind and dxy_c < dxy_o and dxy_c < dxy_o[2]
// Raw signals before mutual-exclusivity check
bool _dxy_bull_raw = bull_eng or bull_pin or bull_3b
bool _dxy_bear_raw = bear_eng or bear_pin or bear_3b
// Body direction tiebreaker: bullish body (dxy_c>dxy_o) → keep bull; bearish → keep bear; doji → suppress both
bool _dxy_both     = _dxy_bull_raw and _dxy_bear_raw
dxy_bull_sig = _dxy_bull_raw and not (_dxy_both and dxy_c <= dxy_o)
dxy_bear_sig = _dxy_bear_raw and not (_dxy_both and dxy_c >= dxy_o)

// ─── LON_ATTR DXY PIN BAR (always active — independent of use_pin input) ──────
// Computed from DXY candle data. Independent of use_pin toggle.
la_dxy_bp_r = dxy_lw >= dxy_bs * pin_wick_mult and dxy_lw >= dxy_uw * 1.5 and dxy_cr > 0
la_dxy_brp_r = dxy_uw >= dxy_bs * pin_wick_mult and dxy_uw >= dxy_lw * 1.5 and dxy_cr > 0
bool _la_dxy_pb = la_dxy_bp_r and la_dxy_brp_r
la_dxy_bull_pin = la_dxy_bp_r  and not (_la_dxy_pb and dxy_c <= dxy_o)
la_dxy_bear_pin = la_dxy_brp_r and not (_la_dxy_pb and dxy_c >= dxy_o)

// ─── DXY DISTANCE FROM OPENING LEVEL ─────────────────────────────────────────
float dxy_dist_from_open = not na(dxy_london_open) ? (dxy_c - dxy_london_open) * 10000 : na
bool  dxy_at_open_level  = not na(dxy_dist_from_open) and math.abs(dxy_dist_from_open) <= rev_proximity

// ─── DXY REVERSAL SL/TP (structural — converted to pair price) ───────────────
float dxy_rl_raw_sl  = na(dxy_pd_low)  ? dxy_c - max_sl_pts / 10000.0 : dxy_pd_low  - struct_sl_buf / 10000.0
float dxy_rl_sl      = math.max(dxy_rl_raw_sl,  dxy_c - max_sl_pts / 10000.0)
float dxy_rl_sl_d    = dxy_c - dxy_rl_sl          // DXY pts (decimal)
float dxy_rs_raw_sl  = na(dxy_pd_high) ? dxy_c + max_sl_pts / 10000.0 : dxy_pd_high + struct_sl_buf / 10000.0
float dxy_rs_sl      = math.min(dxy_rs_raw_sl, dxy_c + max_sl_pts / 10000.0)
float dxy_rs_sl_d    = dxy_rs_sl - dxy_c          // DXY pts (decimal)

// ─── DXY ATTRACTION SL/TP ────────────────────────────────────────────────────
// Near-edge TP stops just short of the gap-fill target
float dxy_al_tp     = attr_use_near_tp ? dxy_attr_target - attr_near_buf / 10000.0 : dxy_attr_target
float dxy_as_tp     = attr_use_near_tp ? dxy_attr_target + attr_near_buf / 10000.0 : dxy_attr_target
float dxy_al_sl_d   = not na(dxy_al_tp) ? dxy_al_tp - dxy_c : na   // +ve → long (TP above)
float dxy_as_sl_d   = not na(dxy_as_tp) ? dxy_c - dxy_as_tp : na   // +ve → short (TP below)
float dxy_al_reward = not na(dxy_al_sl_d) ? dxy_al_sl_d * 10000 : 0.0
float dxy_as_reward = not na(dxy_as_sl_d) ? dxy_as_sl_d * 10000 : 0.0

// ─── LON_ATTR DXY TP / SL (1:1 R:R) ─────────────────────────────────────────
// TP  = dxy_lon_zone_bot (near edge of the DXY London session open candle body)
//         LONG  : zone_bot is the nearest body edge above a below-open entry
//         SHORT : zone_bot is the far body edge below an above-open entry
// SL  = 1:1 mirror of TP distance on the opposite side of entry
//   Long : entry BELOW zone_bot → sl_d = zone_bot − dxy_c (> 0 required) → SL = dxy_c − sl_d
//   Short: entry ABOVE zone_bot → sl_d = dxy_c − zone_bot (> 0 required) → SL = dxy_c + sl_d
// Condition guard (sl_d > 0) ensures TP is in the correct direction before firing.
float dxy_la_long_tp    = dxy_lon_zone_bot
float dxy_la_long_sl_d  = dxy_lon_zone_bot - dxy_c      // TP distance (must be > 0)
float dxy_la_long_sl    = dxy_c - dxy_la_long_sl_d      // 1:1 mirror below entry

// ─── REVERSAL CONDITIONS (DXY) ────────────────────────────────────────────────
bool rev_long_cond  = (rev_enabled and not na(dxy_london_open) and
    in_rev_sess and not in_japan and
    dxy_max_move_down >= rev_min_move and
    dxy_at_open_level and
    dxy_bull_sig and
    dxy_bb_1h == 1 and
    not na(dxy_pd_low) and dxy_rl_sl_d > 0)

bool rev_short_cond = (rev_enabled and not na(dxy_london_open) and
    in_rev_sess and not in_japan and
    dxy_max_move_up >= rev_min_move and
    dxy_at_open_level and
    dxy_bear_sig and
    dxy_bb_1h == -1 and
    not na(dxy_pd_high) and dxy_rs_sl_d > 0)

// ─── ATTR CORE PER-BAR CALCULATIONS (DXY) ────────────────────────────────────
float dxy_wave_ext = 0.0
if not na(dxy_lon_open_close)
    if dxy_attr_gap_pts < 0
        dxy_wave_ext := math.max((dxy_lon_open_close - dxy_c) * 10000, 0.0)
    else if dxy_attr_gap_pts > 0
        dxy_wave_ext := math.max((dxy_c - dxy_lon_open_close) * 10000, 0.0)

bool dxy_impl_long  = (dxy_c - dxy_c[3]) * 10000 >= attr_approach_min
bool dxy_impl_short = (dxy_c[3] - dxy_c) * 10000 >= attr_approach_min

bool dxy_core_ok = (not na(dxy_lon_open_close) and
    dxy_gap_at_lon < core_gap_max and dxy_wave_ext < core_wave_max)

// ─── GAP REJECTION CONDITIONS (DXY) ──────────────────────────────────────────
// Same filters as ATTR but fires AFTER gap has been filled (attr_gap_touched = true)
bool gap_rej_long_cond  = (attr_enabled and not na(dxy_attr_target) and not attr_traded and attr_gap_touched and
    in_sess and not in_japan and
    dxy_attr_gap_pts < -attr_min_gap and
    dxy_c < dxy_attr_target and
    dxy_pd_range <= attr_max_prev_range and
    dxy_bb_4h == 0 and
    dxy_bull_sig and
    dxy_al_reward >= attr_min_reward and
    not na(dxy_al_sl_d) and dxy_al_sl_d > 0)

bool gap_rej_short_cond = (attr_enabled and not na(dxy_attr_target) and not attr_traded and attr_gap_touched and
    in_sess and not in_japan and
    dxy_attr_gap_pts > attr_min_gap and
    dxy_c > dxy_attr_target and
    dxy_pd_range <= attr_max_prev_range and
    dxy_bb_4h == 0 and
    dxy_bear_sig and
    dxy_as_reward >= attr_min_reward and
    not na(dxy_as_sl_d) and dxy_as_sl_d > 0)

// Block further GAP_REJ signals once traded this session
if gap_rej_long_cond or gap_rej_short_cond
    attr_traded := true

// ─── ATTR CORE CONDITIONS (DXY) ──────────────────────────────────────────────
// Zone NOT yet touched. Pair direction filtered by attr_core_dir input.
// ATTR CORE SHORT on DXY: use for EURUSD/AUDUSD/NZDUSD/USDCAD/USDJPY (pair_dir determines actual entry side)
// ATTR CORE LONG on DXY:  use for XAUUSD only (DXY long = XAUUSD short, so pair_dir=-1 → strategy.short)
bool attr_core_long_cond = (attr_core_enabled and not na(dxy_attr_target) and not attr_traded
    and not attr_gap_touched
    and in_sess and not in_japan
    and not na(dxy_lon_open_close)
    and dxy_attr_gap_pts < -attr_min_gap          // gap down setup
    and dxy_c < dxy_attr_tokyo_open               // still below zone near edge
    and dxy_al_reward >= attr_min_reward
    and dxy_pd_range <= attr_max_prev_range
    and dxy_bb_4h == 0
    and dxy_bull_sig
    and dxy_impl_long
    and dxy_core_ok
    and not na(dxy_al_sl_d) and dxy_al_sl_d > 0
    and (attr_core_dir == "LONG only" or attr_core_dir == "Both"))

bool attr_core_short_cond = (attr_core_enabled and not na(dxy_attr_target) and not attr_traded
    and not attr_gap_touched
    and in_sess and not in_japan
    and not na(dxy_lon_open_close)
    and dxy_attr_gap_pts > attr_min_gap           // gap up setup
    and dxy_c > dxy_attr_tokyo_open               // still above zone near edge
    and dxy_as_reward >= attr_min_reward
    and dxy_pd_range <= attr_max_prev_range
    and dxy_bb_4h == 0
    and dxy_bear_sig
    and dxy_impl_short
    and dxy_core_ok
    and not na(dxy_as_sl_d) and dxy_as_sl_d > 0
    and (attr_core_dir == "SHORT only" or attr_core_dir == "Both"))

if attr_core_long_cond or attr_core_short_cond
    attr_traded := true

// ─── LON_ATTR CONDITIONS (DXY) ───────────────────────────────────────────────
// LONG only. SHORT direction dropped — HTF analysis shows SHORT negative across all regimes.
// Pristine: no DXY candle open/close has touched zone_top since London open.
// 4H BB must be flat — counter-trend 4H environments responsible for -22.2R drag.
// One signal per session (lon_attr_traded).

bool lon_attr_long_cond = (lon_attr_enabled and
    not lon_attr_traded and
    not na(dxy_london_open) and
    in_lon_attr_sess and not in_japan and
    dxy_dist_from_open <= -lon_attr_min_long and   // DXY >= min_long pts BELOW London open
    dxy_pristine_long and                           // pristine: no DXY candle open/close touched zone top
    dxy_bb_4h == 0 and                             // 4H BB flat — eliminates counter-trend drag
    dxy_la_long_sl_d > 0 and                       // zone_bot must be above entry (valid TP)
    la_dxy_bull_pin)                                // DXY bull pin bar only

if lon_attr_long_cond
    lon_attr_traded := true

float cr_px = high - low  // pair candle range for label offset

// ─── ENTRIES — DXY-EXIT APPROACH ─────────────────────────────────────────────
// Positions are entered on the pair chart but CLOSED when DXY crosses its own
// TP or SL level (see DXY EXIT block below). No pair-price strategy.exit calls.
// tick_factor input retained for display purposes but no longer used for exit calc.

// — GAP REJECTION LONG (DXY gap filled, price pulled back, bull signal) ────────
if in_window and gap_rej_long_cond
    dxy_tp_lvl     := dxy_al_tp
    dxy_sl_lvl     := dxy_c - dxy_al_sl_d
    dxy_trade_long := true
    dxy_exit_track := true
    dxy_entry_bar  := bar_index
    int tdir = pair_dir
    if tdir == 1
        strategy.entry("GapRej Long", strategy.long)
        label.new(bar_index, low - cr_px, "▲ GAP REJ↑\n" + str.tostring(math.round(math.abs(dxy_attr_gap_pts))) + " pt gap",
            color=color.new(color.orange, 10), textcolor=color.white, style=label.style_label_up, size=size.small)
    else
        strategy.entry("GapRej Long", strategy.short)
        label.new(bar_index, high + cr_px, "▼ GAP REJ↑\n" + str.tostring(math.round(math.abs(dxy_attr_gap_pts))) + " pt gap",
            color=color.new(color.orange, 10), textcolor=color.white, style=label.style_label_down, size=size.small)

// — GAP REJECTION SHORT (DXY gap filled, price pulled back, bear signal) ───────
if in_window and gap_rej_short_cond
    dxy_tp_lvl     := dxy_as_tp
    dxy_sl_lvl     := dxy_c + dxy_as_sl_d
    dxy_trade_long := false
    dxy_exit_track := true
    dxy_entry_bar  := bar_index
    int tdir = -1 * pair_dir
    if tdir == 1
        strategy.entry("GapRej Short", strategy.long)
        label.new(bar_index, low - cr_px, "▲ GAP REJ↓\n" + str.tostring(math.round(dxy_attr_gap_pts)) + " pt gap",
            color=color.new(color.orange, 10), textcolor=color.white, style=label.style_label_up, size=size.small)
    else
        strategy.entry("GapRej Short", strategy.short)
        label.new(bar_index, high + cr_px, "▼ GAP REJ↓\n" + str.tostring(math.round(dxy_attr_gap_pts)) + " pt gap",
            color=color.new(color.orange, 10), textcolor=color.white, style=label.style_label_down, size=size.small)

// — REVERSAL LONG (DXY bouncing up at opening level) ─────────────────────────
if in_window and rev_long_cond
    dxy_tp_lvl     := dxy_c + dxy_rl_sl_d      // DXY TP = entry + SL distance (1:1 above)
    dxy_sl_lvl     := dxy_rl_sl                 // DXY SL = structural (prior day low − buf)
    dxy_trade_long := true
    dxy_exit_track := true
    dxy_entry_bar  := bar_index
    int tdir = pair_dir
    if tdir == 1
        strategy.entry("Rev Long", strategy.long)
        label.new(bar_index, low - cr_px, "▲ REV↑\nSL " + str.tostring(math.round(dxy_rl_sl_d * 10000)) + " pts",
            color=color.new(color.teal, 10), textcolor=color.white, style=label.style_label_up, size=size.small)
    else
        strategy.entry("Rev Long", strategy.short)
        label.new(bar_index, high + cr_px, "▼ REV↑\nSL " + str.tostring(math.round(dxy_rl_sl_d * 10000)) + " pts",
            color=color.new(color.teal, 10), textcolor=color.white, style=label.style_label_down, size=size.small)

// — REVERSAL SHORT (DXY rejecting down at opening level) ──────────────────────
if in_window and rev_short_cond
    dxy_tp_lvl     := dxy_c - dxy_rs_sl_d      // DXY TP = entry − SL distance (1:1 below)
    dxy_sl_lvl     := dxy_rs_sl                 // DXY SL = structural (prior day high + buf)
    dxy_trade_long := false
    dxy_exit_track := true
    dxy_entry_bar  := bar_index
    int tdir = -1 * pair_dir
    if tdir == 1
        strategy.entry("Rev Short", strategy.long)
        label.new(bar_index, low - cr_px, "▲ REV↓\nSL " + str.tostring(math.round(dxy_rs_sl_d * 10000)) + " pts",
            color=color.new(color.purple, 10), textcolor=color.white, style=label.style_label_up, size=size.small)
    else
        strategy.entry("Rev Short", strategy.short)
        label.new(bar_index, high + cr_px, "▼ REV↓\nSL " + str.tostring(math.round(dxy_rs_sl_d * 10000)) + " pts",
            color=color.new(color.purple, 10), textcolor=color.white, style=label.style_label_down, size=size.small)

// — LON_ATTR LONG (DXY bull pin bar, pristine, >= 1000 pts below DXY London open, 4H flat) ─
if in_window and lon_attr_long_cond
    dxy_tp_lvl     := dxy_la_long_tp            // DXY TP = zone near edge (dxy_lon_zone_bot)
    dxy_sl_lvl     := dxy_la_long_sl            // DXY SL = 1:1 mirror below entry
    dxy_trade_long := true
    dxy_exit_track := true
    dxy_entry_bar  := bar_index
    int tdir = pair_dir
    if tdir == 1
        strategy.entry("LonAttr Long", strategy.long)
        label.new(bar_index, low - cr_px, "▲ LON_ATTR↑\n" + str.tostring(math.round(-dxy_dist_from_open)) + " pts below open  |  4H flat",
            color=color.new(color.navy, 10), textcolor=color.white, style=label.style_label_up, size=size.small)
    else
        strategy.entry("LonAttr Long", strategy.short)
        label.new(bar_index, high + cr_px, "▼ LON_ATTR↑\n" + str.tostring(math.round(-dxy_dist_from_open)) + " pts below open  |  4H flat",
            color=color.new(color.navy, 10), textcolor=color.white, style=label.style_label_down, size=size.small)

// — ATTR CORE LONG (DXY gap down, first approach, zone pristine, CORE filter passed) ─────
// DXY LONG → pair_dir=+1 goes LONG, pair_dir=-1 goes SHORT (e.g. XAUUSD: DXY up = Gold down)
if in_window and attr_core_long_cond
    dxy_tp_lvl     := dxy_al_tp
    dxy_sl_lvl     := dxy_c - dxy_al_sl_d
    dxy_trade_long := true
    dxy_exit_track := true
    dxy_entry_bar  := bar_index
    int tdir = pair_dir
    if tdir == 1
        strategy.entry("AttrCore Long", strategy.long)
        label.new(bar_index, low - cr_px,
            "▲ CORE↑\nGap@Lon: " + str.tostring(math.round(dxy_gap_at_lon)) + " pts  |  Wave: " + str.tostring(math.round(dxy_wave_ext)) + " pts",
            color=color.new(color.blue, 10), textcolor=color.white, style=label.style_label_up, size=size.small)
    else
        strategy.entry("AttrCore Long", strategy.short)
        label.new(bar_index, high + cr_px,
            "▼ CORE↑\nGap@Lon: " + str.tostring(math.round(dxy_gap_at_lon)) + " pts  |  Wave: " + str.tostring(math.round(dxy_wave_ext)) + " pts",
            color=color.new(color.blue, 10), textcolor=color.white, style=label.style_label_down, size=size.small)

// — ATTR CORE SHORT (DXY gap up, first approach, zone pristine, CORE filter passed) ─────
// DXY SHORT → pair_dir=+1 goes SHORT, pair_dir=-1 goes LONG (e.g. EURUSD: DXY down = EUR up)
if in_window and attr_core_short_cond
    dxy_tp_lvl     := dxy_as_tp
    dxy_sl_lvl     := dxy_c + dxy_as_sl_d
    dxy_trade_long := false
    dxy_exit_track := true
    dxy_entry_bar  := bar_index
    int tdir = -1 * pair_dir
    if tdir == 1
        strategy.entry("AttrCore Short", strategy.long)
        label.new(bar_index, low - cr_px,
            "▲ CORE↓\nGap@Lon: " + str.tostring(math.round(dxy_gap_at_lon)) + " pts  |  Wave: " + str.tostring(math.round(dxy_wave_ext)) + " pts",
            color=color.new(color.blue, 10), textcolor=color.white, style=label.style_label_up, size=size.small)
    else
        strategy.entry("AttrCore Short", strategy.short)
        label.new(bar_index, high + cr_px,
            "▼ CORE↓\nGap@Lon: " + str.tostring(math.round(dxy_gap_at_lon)) + " pts  |  Wave: " + str.tostring(math.round(dxy_wave_ext)) + " pts",
            color=color.new(color.blue, 10), textcolor=color.white, style=label.style_label_down, size=size.small)

// ─── DXY EXIT ────────────────────────────────────────────────────────────────
// Close all pair positions when DXY crosses its TP or SL level.
// bar_index > dxy_entry_bar prevents same-bar entry + exit conflict.
// pair_is_long = true when the PAIR trade direction is long (accounts for pair_dir inversion).
//   DXY long + pair_dir +1 → pair long  (USDJPY/USDCAD go up when DXY goes up)
//   DXY long + pair_dir -1 → pair short (EURUSD/XAUUSD go down when DXY goes up)
//   DXY short + pair_dir +1 → pair short
//   DXY short + pair_dir -1 → pair long
if dxy_exit_track and not na(dxy_tp_lvl) and not na(dxy_sl_lvl) and bar_index > dxy_entry_bar
    bool dxy_tp_cross  = dxy_trade_long ? dxy_h >= dxy_tp_lvl : dxy_l <= dxy_tp_lvl
    bool dxy_sl_cross  = dxy_trade_long ? dxy_l <= dxy_sl_lvl : dxy_h >= dxy_sl_lvl
    bool pair_is_long  = (dxy_trade_long and pair_dir == 1) or (not dxy_trade_long and pair_dir == -1)
    if dxy_tp_cross
        strategy.close_all(comment="DXY TP")
        dxy_exit_track := false
        dxy_tp_lvl     := na
        dxy_sl_lvl     := na
        // TP hit: pair went in our favour — long pair price rose (label above), short pair price fell (label below)
        label.new(bar_index, pair_is_long ? high + cr_px : low - cr_px,
            "✔ DXY TP",
            color=color.new(color.lime, 10), textcolor=color.black,
            style=pair_is_long ? label.style_label_down : label.style_label_up, size=size.small)
    else if dxy_sl_cross
        strategy.close_all(comment="DXY SL")
        dxy_exit_track := false
        dxy_tp_lvl     := na
        dxy_sl_lvl     := na
        // SL hit: pair went against us — long pair price fell (label below), short pair price rose (label above)
        label.new(bar_index, pair_is_long ? low - cr_px : high + cr_px,
            "✘ DXY SL",
            color=color.new(color.red, 10), textcolor=color.white,
            style=pair_is_long ? label.style_label_up : label.style_label_down, size=size.small)

// ─── VISUALS ─────────────────────────────────────────────────────────────────
bgcolor(show_session and in_sess ? color.new(color.blue, 93) : na, title="London Session")

// DXY opening level plotted on pair chart (visual reference only — not a pair price level)
plot(show_dxy_lvl and not na(dxy_london_open) ? dxy_london_open : na,
    "DXY Opening Level (reference)", color=color.new(color.yellow, 40), linewidth=1,
    style=plot.style_linebr)
