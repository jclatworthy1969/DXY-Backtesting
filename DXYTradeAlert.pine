//@version=6
indicator("DXY Trade Alert", overlay=true, max_labels_count=500)

// ─── INPUTS ──────────────────────────────────────────────────────────────────
grp_zone = "Signal Zones & Tolerance"
grp_sess = "Session Window (GMT)"
grp_sig  = "Entry Signals"
grp_htf  = "HTF Bias (Reversal Gate)"
grp_disp = "Display"

attr_enabled  = input.bool(true,  "Enable Attraction Trade Alerts",            group=grp_zone)
attr_min_pts  = input.int(1500,   "Attraction — Min Distance from Zone (pts)", group=grp_zone, minval=10, step=10, tooltip="1500 pts = 150 DXY points = 0.150 price move. Minimum gap from zone edge to entry.")
zone_min_gap  = input.int(30,     "Zone — Min Gap to use open gap (pts)",      group=grp_zone, minval=5, step=5, tooltip="If gap between prior close and 23:45 open is smaller than this, the 23:45 candle body is used as the zone instead.")
attr_max_pts  = input.int(5000,   "Attraction — Max Distance from Zone (pts)", group=grp_zone, minval=500, step=100, tooltip="Upper bound. Beyond this, momentum may be too strong.")
rev_enabled   = input.bool(true,  "Enable Reversal Trade Alerts",              group=grp_zone)
rev_min_sl    = input.int(3000,   "Reversal — Min Structural SL (pts)",        group=grp_zone, minval=500, step=500, tooltip="Minimum SL distance for reversal entries. Applies in the strategy script only. Backtest finding: reversals with structural SL ≥3000 pts have 77%+ WR; ≥5000 pts = 100% WR across 302 trades. Entry itself should be AT or near the zone (not gated by this distance).")
rev_max_dist  = input.int(500,    "Reversal — Max Distance from Zone (pts)",   group=grp_zone, minval=50, step=50, tooltip="Reversal signal only fires when price is within this many pts of the zone edge. Keeps entries AT the zone rather than midair. Default 500 pts = 50 DXY points.")

entry_start_h = input.int(7,  "Entry Start Hour (GMT)",              group=grp_sess, minval=0, maxval=23, tooltip="Entry window start — 07:30 GMT (= 2:30 AM Eastern, per strategy rules). Monday exception uses monday_start instead.")
entry_start_m = input.int(30, "Entry Start Minute (GMT)",            group=grp_sess, minval=0, maxval=59)
entry_end_h   = input.int(19, "Entry End Hour (GMT)",                group=grp_sess, minval=0, maxval=23, tooltip="Entry window ends at 19:30 GMT, covering London through NY afternoon.")
entry_end_m   = input.int(30, "Entry End Minute (GMT)",              group=grp_sess, minval=0, maxval=59)
rev_end_h     = input.int(12, "Reversal — Entry End Hour (GMT)",     group=grp_sess, minval=8, maxval=19, tooltip="Reversals fire only during the morning London session. Backtesting shows all winning reversals entered before 12:00 GMT. Attraction trades still run until entry_end_h.")
rev_end_m     = input.int(0,  "Reversal — Entry End Min  (GMT)",     group=grp_sess, minval=0, maxval=59)
monday_start  = input.int(6,  "Monday Start Hour (GMT)",             group=grp_sess, minval=0, maxval=23, tooltip="Monday entry starts at 06:30 GMT (= 1:30 AM Eastern). Earlier than standard days due to weekend gap volatility.")
japan_end_h   = input.int(6,  "Japan Session End Hour (GMT)",        group=grp_sess, minval=1, maxval=8)

use_engulf    = input.bool(true,  "Engulfing Candle",        group=grp_sig)
use_pin       = input.bool(true,  "Pin Bar",                 group=grp_sig)
use_3bar      = input.bool(true,  "3-Bar Reversal",          group=grp_sig)
pin_wick_mult = input.float(2.0,  "Pin Bar — Min Wick:Body", group=grp_sig, minval=1.0, step=0.25)

div_lookback  = input.int(30,   "Divergence Lookback (bars)",       group=grp_htf, minval=10, maxval=100, step=5,  tooltip="Bars to look back when measuring divergence. Controls the window across which price vs oscillator extremes are compared. 30 bars on 15m ≈ 7.5 hours.")
rev_min_div   = input.int(2,   "Min Divergence Score (1–6)",       group=grp_htf, minval=1,  maxval=6,            tooltip="Minimum number of oscillators showing divergence before a reversal signal fires. Mirrors the AlgoPro Market Matrix score. 1 = weak, 3+ = strong, 5–6 = very high conviction.")
show_div_info = input.bool(true, "Show Divergence Score on Labels", group=grp_htf,                               tooltip="Adds the divergence score and per-oscillator breakdown to reversal label text.")

show_zone_box  = input.bool(true, "Show Open Zone (shaded box)",    group=grp_disp)
show_attr_band = input.bool(true, "Show Attraction Distance Bands", group=grp_disp)
show_session   = input.bool(true, "Show London Session Background", group=grp_disp)

// ─── SESSION TIMING ──────────────────────────────────────────────────────────
h        = hour(time, "UTC")
m        = minute(time, "UTC")
is_mon   = dayofweek(time, "UTC") == dayofweek.monday
start_min = (is_mon ? monday_start : entry_start_h) * 60 + entry_start_m
curr_min  = h * 60 + m
end_min   = entry_end_h * 60 + entry_end_m
in_sess     = curr_min >= start_min and curr_min <= end_min
rev_end_min = rev_end_h * 60 + rev_end_m
in_rev_sess = curr_min >= start_min and curr_min <= rev_end_min
in_japan = (h == 23 and m >= 45) or (h >= 0 and h < japan_end_h)
is_2345  = h == 23 and m == 45

// ─── DXY OPEN ZONE ───────────────────────────────────────────────────────────
// Primary zone: gap between the close of the candle immediately before 23:45
// and the 23:45 candle open. If the gap is smaller than zone_min_gap pts,
// the body of the 23:45 candle (open-to-close) is used as the zone instead,
// ensuring a meaningful structural reference even on flat opens.
//
// PRISTINE: all Japan session closes remain on the same side of the zone they started.
// Closes INSIDE the zone are acceptable — pristine is only broken when a close
// crosses THROUGH to the OPPOSITE side (beyond the far edge).

var float zone_top        = na
var float zone_bottom     = na
var bool  zone_pristine   = false   // reversal condition: no close beyond far edge
var bool  zone_body_clean = false   // attraction condition: no body inside zone after 2nd candle
var bool  japan_bull      = false   // true = Japan session is above the zone
var int   japan_candle_count = 0    // candles elapsed since 23:45 (0 = the 23:45 bar itself)

if is_2345
    // If the immediately prior candle is a line candle (no meaningful body — common on Monday
    // weekend open), skip it and use the candle before that instead.
    bool  prior_is_line      = math.abs(close[1] - open[1]) * 10000 < 10
    float prior_candle_close = prior_is_line ? close[2] : close[1]
    float japan_open         = open       // open of the 23:45 candle
    float gap_size           = math.abs(prior_candle_close - japan_open) * 10000
    if gap_size >= zone_min_gap
        // Noticeable gap: use the open-gap as the zone
        zone_top    := math.max(prior_candle_close, japan_open)
        zone_bottom := math.min(prior_candle_close, japan_open)
        japan_bull  := japan_open > prior_candle_close
    else
        // No noticeable gap: use the 23:45 candle body
        zone_top    := math.max(japan_open, close)
        zone_bottom := math.min(japan_open, close)
        japan_bull  := close > japan_open
    zone_pristine      := true
    zone_body_clean    := true
    japan_candle_count := 0

// Monitor Japan session (23:45 onwards through to japan_end_h)
// zone_pristine: broken only if close goes BEYOND the far edge (reversal condition)
// zone_body_clean: first 3 candles may close inside zone; from candle 4 onward any close inside breaks it
if in_japan and not na(zone_top) and not is_2345
    japan_candle_count := japan_candle_count + 1

    if zone_body_clean and japan_candle_count > 3
        bool close_in_zone = close >= zone_bottom and close <= zone_top
        if close_in_zone
            zone_body_clean := false

    if zone_pristine
        if japan_bull
            if close < zone_bottom
                zone_pristine := false
        else
            if close > zone_top
                zone_pristine := false

// ─── CANDLE MEASUREMENTS ─────────────────────────────────────────────────────
body_sz    = math.abs(close - open)
upper_wick = high - math.max(open, close)
lower_wick = math.min(open, close) - low
cndl_range = high - low
is_bull    = close > open
is_bear    = close < open

// ─── ENTRY SIGNALS ───────────────────────────────────────────────────────────
bull_engulf   = use_engulf and is_bull and not is_bull[1] and close > open[1] and open < close[1] and body_sz >= body_sz[1] * 0.8
bear_engulf   = use_engulf and is_bear and not is_bear[1] and close < open[1] and open > close[1] and body_sz >= body_sz[1] * 0.8
bull_pin      = use_pin and lower_wick >= body_sz * pin_wick_mult and upper_wick <= body_sz * 1.5 and cndl_range > 0
bear_pin      = use_pin and upper_wick >= body_sz * pin_wick_mult and lower_wick <= body_sz * 1.5 and cndl_range > 0
bar2_range    = math.abs(close[2] - open[2])
indecision    = body_sz[1] <= bar2_range * 0.5
bull_3bar     = use_3bar and close[2] < open[2] and indecision and is_bull and close > open[2]
bear_3bar     = use_3bar and close[2] > open[2] and indecision and is_bear and close < open[2]
bull_sig      = bull_engulf or bull_pin or bull_3bar
bear_sig      = bear_engulf or bear_pin or bear_3bar
bull_sig_name = bull_engulf ? "Engulfing" : bull_pin ? "Pin Bar" : bull_3bar ? "3-Bar Reversal" : "Signal"
bear_sig_name = bear_engulf ? "Engulfing" : bear_pin ? "Pin Bar" : bear_3bar ? "3-Bar Reversal" : "Signal"

// ─── DIVERGENCE SCORER (AlgoPro Market Matrix proxy) ─────────────────────────
// Counts how many of 6 oscillators show divergence against current price position.
// Bullish divergence: price near its lookback LOW but oscillator NOT near its low
//   → oscillator is recovering while price still depressed = momentum building
// Bearish divergence: price near its lookback HIGH but oscillator NOT near its high
//   → oscillator is fading while price still elevated = momentum exhausting
// Score 0–6. rev_min_div controls the minimum score for a reversal to fire.

rsi_val                       = ta.rsi(close, 14)
[macd_line, macd_sig, macd_h] = ta.macd(close, 12, 26, 9)
stoch_k                       = ta.stoch(close, high, low, 14)
cci_val                       = ta.cci(hlc3, 20)
wpr_val                       = ta.wpr(14)
mom_val                       = ta.mom(close, 10)

// Price position within lookback range (bottom/top 30% = "at extreme")
price_lo  = ta.lowest (close, div_lookback)
price_hi  = ta.highest(close, div_lookback)
price_rng = price_hi - price_lo
price_bot = price_rng > 0 and close <= price_lo + price_rng * 0.30
price_top = price_rng > 0 and close >= price_hi - price_rng * 0.30

// Helper: oscillator NOT at its lookback extreme (= diverging from price)
f_not_bot(val) =>
    lo  = ta.lowest (val, div_lookback)
    hi  = ta.highest(val, div_lookback)
    rng = hi - lo
    rng > 0 and val > lo + rng * 0.30

f_not_top(val) =>
    lo  = ta.lowest (val, div_lookback)
    hi  = ta.highest(val, div_lookback)
    rng = hi - lo
    rng > 0 and val < hi - rng * 0.30

// Pre-compute function results unconditionally so ta.lowest/ta.highest history stays consistent
_nb_rsi   = f_not_bot(rsi_val)
_nb_macd  = f_not_bot(macd_h)
_nb_stoch = f_not_bot(stoch_k)
_nb_cci   = f_not_bot(cci_val)
_nb_wpr   = f_not_bot(wpr_val)
_nb_mom   = f_not_bot(mom_val)

_nt_rsi   = f_not_top(rsi_val)
_nt_macd  = f_not_top(macd_h)
_nt_stoch = f_not_top(stoch_k)
_nt_cci   = f_not_top(cci_val)
_nt_wpr   = f_not_top(wpr_val)
_nt_mom   = f_not_top(mom_val)

// Per-oscillator divergence flags (combine price position with oscillator status)
bd_rsi   = price_bot and _nb_rsi
bd_macd  = price_bot and _nb_macd
bd_stoch = price_bot and _nb_stoch
bd_cci   = price_bot and _nb_cci
bd_wpr   = price_bot and _nb_wpr
bd_mom   = price_bot and _nb_mom

bk_rsi   = price_top and _nt_rsi
bk_macd  = price_top and _nt_macd
bk_stoch = price_top and _nt_stoch
bk_cci   = price_top and _nt_cci
bk_wpr   = price_top and _nt_wpr
bk_mom   = price_top and _nt_mom

// Aggregate scores and reversal gates
bull_div_score = (bd_rsi ? 1 : 0) + (bd_macd ? 1 : 0) + (bd_stoch ? 1 : 0) + (bd_cci ? 1 : 0) + (bd_wpr ? 1 : 0) + (bd_mom ? 1 : 0)
bear_div_score = (bk_rsi ? 1 : 0) + (bk_macd ? 1 : 0) + (bk_stoch ? 1 : 0) + (bk_cci ? 1 : 0) + (bk_wpr ? 1 : 0) + (bk_mom ? 1 : 0)
htf_bull       = bull_div_score >= rev_min_div
htf_bear       = bear_div_score >= rev_min_div

// ─── DISTANCE FROM ZONE ──────────────────────────────────────────────────────
// Attraction: measured to FAR side (= TP target)
// Reversal proximity: absolute distance from zone edge — entry must be within
//   rev_max_dist pts of the zone edge (ensures entries are AT the zone, not midair)
dist_to_tp_short = (close - zone_bottom) * 10000
dist_to_tp_long  = (zone_top - close)    * 10000
dist_rev_long    = math.abs(close - zone_bottom) * 10000   // proximity to zone_bottom (rev long ref)
dist_rev_short   = math.abs(zone_top - close)    * 10000   // proximity to zone_top   (rev short ref)

// ─── ATTRACTION CONDITIONS (zone must be BOTH body-clean AND pristine) ───────
// zone_body_clean alone is not sufficient — if a Japan candle closes beyond the
// far edge of the zone (breaking zone_pristine), the zone is structurally broken
// and no attraction trades are valid, even if no body has closed inside the zone.
// Once zone_pristine is false, only Reversal setups apply.
attr_short = attr_enabled and zone_body_clean and zone_pristine and japan_bull     and in_sess and bear_sig and dist_to_tp_short >= attr_min_pts and dist_to_tp_short <= attr_max_pts
attr_long  = attr_enabled and zone_body_clean and zone_pristine and not japan_bull and in_sess and bull_sig and dist_to_tp_long  >= attr_min_pts and dist_to_tp_long  <= attr_max_pts

// ─── REVERSAL CONDITIONS (broken zone only) ──────────────────────────────────
// Three coded gates (all must pass):
//   1. Zone broken (not zone_pristine) + morning session (in_rev_sess)
//   2. Divergence score >= rev_min_div (AlgoPro Market Matrix proxy)
//   3. Proximity: entry within rev_max_dist pts of zone edge
// Plus a valid candlestick signal. Insufficient divergence score = no signal.
rev_short = rev_enabled and not zone_pristine and in_rev_sess and bear_sig and htf_bear and dist_rev_short <= rev_max_dist
rev_long  = rev_enabled and not zone_pristine and in_rev_sess and bull_sig and htf_bull and dist_rev_long  <= rev_max_dist

// ─── PLOTS ───────────────────────────────────────────────────────────────────
zone_edge_col = zone_pristine ? color.new(color.orange, 20) : color.new(color.gray, 40)
zone_fill_col = zone_pristine ? color.new(color.orange, 80) : color.new(color.gray, 85)

p_top = plot(not na(zone_top)    and show_zone_box ? zone_top    : na, "Zone Top",    color=zone_edge_col, linewidth=2)
p_bot = plot(not na(zone_bottom) and show_zone_box ? zone_bottom : na, "Zone Bottom", color=zone_edge_col, linewidth=2)
fill(p_top, p_bot, color=zone_fill_col, title="Open Zone Fill")

plot(show_attr_band and not na(zone_top)    ? zone_top    + attr_max_pts / 10000.0 : na, "Attr Max Above", color=color.new(color.red,   72), linewidth=1)
plot(show_attr_band and not na(zone_bottom) ? zone_bottom - attr_max_pts / 10000.0 : na, "Attr Max Below", color=color.new(color.green, 72), linewidth=1)
plot(show_attr_band and not na(zone_top)    ? zone_top    + attr_min_pts / 10000.0 : na, "Attr Min Above", color=color.new(color.red,   87), linewidth=1, style=plot.style_circles)
plot(show_attr_band and not na(zone_bottom) ? zone_bottom - attr_min_pts / 10000.0 : na, "Attr Min Below", color=color.new(color.green, 87), linewidth=1, style=plot.style_circles)

bgcolor(show_session and in_sess ? color.new(color.blue, 93) : na, title="London Session")

// ─── LABELS ──────────────────────────────────────────────────────────────────
lbl_pad = math.max(cndl_range, nz(zone_top, close) * 0.0003)

if attr_long
    float attr_long_tp  = zone_top
    float attr_long_rr  = attr_long_tp - close
    float attr_long_sl  = close - attr_long_rr
    label.new(bar_index, low - lbl_pad, "▲  ATTRACTION LONG\n" + bull_sig_name + "  |  " + str.tostring(math.round(dist_to_tp_long)) + " pts to TP\nTP: " + str.tostring(attr_long_tp, "#.###") + " (zone top — far side)\nSL: " + str.tostring(attr_long_sl, "#.###") + " (1:1)", color=color.new(color.green, 5), textcolor=color.white, style=label.style_label_up, size=size.normal)

if attr_short
    float attr_short_tp = zone_bottom
    float attr_short_rr = close - attr_short_tp
    float attr_short_sl = close + attr_short_rr
    label.new(bar_index, high + lbl_pad, "▼  ATTRACTION SHORT\n" + bear_sig_name + "  |  " + str.tostring(math.round(dist_to_tp_short)) + " pts to TP\nTP: " + str.tostring(attr_short_tp, "#.###") + " (zone bottom — far side)\nSL: " + str.tostring(attr_short_sl, "#.###") + " (1:1)", color=color.new(color.red, 5), textcolor=color.white, style=label.style_label_down, size=size.normal)

if rev_long
    div_str = show_div_info ? "\nDiv Score: " + str.tostring(bull_div_score) + "/6  [RSI:" + (bd_rsi ? "✔" : "✗") + " MACD:" + (bd_macd ? "✔" : "✗") + " Stoch:" + (bd_stoch ? "✔" : "✗") + " CCI:" + (bd_cci ? "✔" : "✗") + " WPR:" + (bd_wpr ? "✔" : "✗") + " Mom:" + (bd_mom ? "✔" : "✗") + "]" : ""
    label.new(bar_index, low - lbl_pad, "▲  REVERSAL LONG\n" + bull_sig_name + "  |  Zone broken — acts as support\nZone: " + str.tostring(zone_bottom, "#.###") + " – " + str.tostring(zone_top, "#.###") + "\nSL: swing low  |  TP: 1:1 minimum 150 pts" + div_str, color=color.new(color.teal, 5), textcolor=color.white, style=label.style_label_up, size=size.normal)

if rev_short
    div_str = show_div_info ? "\nDiv Score: " + str.tostring(bear_div_score) + "/6  [RSI:" + (bk_rsi ? "✔" : "✗") + " MACD:" + (bk_macd ? "✔" : "✗") + " Stoch:" + (bk_stoch ? "✔" : "✗") + " CCI:" + (bk_cci ? "✔" : "✗") + " WPR:" + (bk_wpr ? "✔" : "✗") + " Mom:" + (bk_mom ? "✔" : "✗") + "]" : ""
    label.new(bar_index, high + lbl_pad, "▼  REVERSAL SHORT\n" + bear_sig_name + "  |  Zone broken — acts as resistance\nZone: " + str.tostring(zone_bottom, "#.###") + " – " + str.tostring(zone_top, "#.###") + "\nSL: swing high  |  TP: 1:1 minimum 150 pts" + div_str, color=color.new(color.purple, 5), textcolor=color.white, style=label.style_label_down, size=size.normal)

// ─── ALERTS ──────────────────────────────────────────────────────────────────
alertcondition(attr_long,  title="DXY Attraction LONG",       message="DXY ATTRACTION LONG\nZone PRISTINE — Japan bearish. Price 150+ DXY pts below zone.\nTP: zone_top (far side) | SL: 1:1\nGo LONG: USDCHF, USDCAD, USDJPY | Go SHORT: EURUSD, GBPUSD, NZDUSD, AUDUSD\nZone top (TP): {{plot_0}} | Price: {{close}} | {{time}}")
alertcondition(attr_short, title="DXY Attraction SHORT",      message="DXY ATTRACTION SHORT\nZone PRISTINE — Japan bullish. Price 150+ DXY pts above zone.\nTP: zone_bottom (far side) | SL: 1:1\nGo SHORT: USDCHF, USDCAD, USDJPY | Go LONG: EURUSD, GBPUSD, NZDUSD, AUDUSD\nZone bottom (TP): {{plot_1}} | Price: {{close}} | {{time}}")
alertcondition(rev_long,   title="DXY Reversal LONG",         message="DXY REVERSAL LONG\nZone BROKEN — zone bottom now acting as support.\nGo LONG: USDCHF, USDCAD, USDJPY | Go SHORT: EURUSD, GBPUSD, NZDUSD, AUDUSD\nZone bottom: {{plot_1}} | Price: {{close}} | {{time}}")
alertcondition(rev_short,  title="DXY Reversal SHORT",        message="DXY REVERSAL SHORT\nZone BROKEN — zone top now acting as resistance.\nGo SHORT: USDCHF, USDCAD, USDJPY | Go LONG: EURUSD, GBPUSD, NZDUSD, AUDUSD\nZone top: {{plot_0}} | Price: {{close}} | {{time}}")
alertcondition(attr_long or attr_short or rev_long or rev_short, title="DXY Trade Alert - Any Setup", message="DXY TRADE ALERT — Setup detected. Check zone status and direction.\nPrice: {{close}} | {{time}}")
