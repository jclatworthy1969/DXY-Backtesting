//@version=6
indicator("DXY Trade Alert", overlay=true, max_labels_count=500)

// ─── INPUTS ──────────────────────────────────────────────────────────────────
grp_zone = "Signal Zones"
grp_sess = "Session Window (GMT)"
grp_sig  = "Entry Signals"
grp_htf  = "HTF Bias (EMA)"
grp_disp = "Display"

// Attraction
attr_enabled     = input.bool(true,  "Enable Attraction Trade Alerts",           group=grp_zone)
attr_min_gap     = input.int(150,    "Attraction — Min Gap at London Open (pts)", group=grp_zone, minval=50,  step=25,  tooltip="Zone must be at least this many pts away from near edge at London open (07:30). Confirms Tokyo left the zone pristine with meaningful separation before the London retracement. Backtest: 150 pts.")
attr_approach    = input.int(150,    "Attraction — Min 3-Bar Approach (pts)",    group=grp_zone, minval=50,  step=25,  tooltip="Minimum net move toward the zone over the prior 3 bars. Confirms impulsive retracement momentum. Backtest: 150 pts.")
attr_min_reward  = input.int(150,    "Attraction — Min Reward to TP (pts)",      group=grp_zone, minval=50,  step=25,  tooltip="Minimum distance from entry close to TP. Ensures worthwhile trade. Backtest: 150 pts.")
attr_near_buffer = input.int(50,     "Attraction — TP Buffer Past Near Edge (pts)", group=grp_zone, minval=0, step=10, tooltip="TP is placed this many pts past the near zone edge (zone_bottom for long, zone_top for short). 50 pts gives the trade a little room to confirm zone interaction. Backtest winner: 50 pts vs full gap fill.")
zone_min_gap     = input.int(30,     "Zone — Min Gap to use open gap (pts)",     group=grp_zone, minval=5,  step=5,   tooltip="If gap between prior close and 23:45 open is smaller than this, the 23:45 candle body is used as the zone instead.")
zone_min_width   = input.int(150,    "Zone — Min Width (pts)",                   group=grp_zone, minval=50, step=25,  tooltip="Minimum zone width (zone_top - zone_bottom). Filters out trivially narrow zones.")
cooldown_bars    = input.int(8,      "Signal Cooldown (bars per zone)",           group=grp_zone, minval=1, maxval=50, tooltip="Suppresses repeat signals of the same type from the same zone for this many bars. 8 bars = 2 hours on 15m chart.")

// Reversal
rev_enabled   = input.bool(true, "Enable Reversal Trade Alerts",              group=grp_zone)
rev_max_dist  = input.int(500,   "Reversal — Max Distance from Zone (pts)",   group=grp_zone, minval=50,  step=50,  tooltip="Reversal signal only fires when price is within this many pts of the zone edge.")
rev_min_body  = input.int(200,   "Reversal — Min Signal Candle Body (pts)",   group=grp_zone, minval=0,  step=25,  tooltip="Filters weak reversal candles. Backtest: body >= 200 pts. Set 0 to disable.")
rev_min_range = input.int(400,   "Reversal — Min Signal Candle Range (pts)",  group=grp_zone, minval=0,  step=25,  tooltip="Filters narrow-range reversal candles. Backtest: range >= 400 pts. Set 0 to disable.")
rev_min_sl    = input.int(3000,  "Reversal — Min Structural SL (pts)",        group=grp_zone, minval=500, step=500, tooltip="Minimum SL distance for reversal entries. Backtest: structural SL >= 3000 pts = 77%+ WR.")

// Session
entry_start_h = input.int(7,  "Entry Start Hour (GMT)",              group=grp_sess, minval=0, maxval=23)
entry_start_m = input.int(30, "Entry Start Minute (GMT)",            group=grp_sess, minval=0, maxval=59)
entry_end_h   = input.int(19, "Entry End Hour (GMT)",                group=grp_sess, minval=0, maxval=23)
entry_end_m   = input.int(30, "Entry End Minute (GMT)",              group=grp_sess, minval=0, maxval=59)
rev_end_h     = input.int(12, "Reversal — Entry End Hour (GMT)",     group=grp_sess, minval=8, maxval=19, tooltip="Reversals fire only during London morning. All winning reversals in backtest entered before 12:00 GMT.")
rev_end_m     = input.int(0,  "Reversal — Entry End Min (GMT)",      group=grp_sess, minval=0, maxval=59)
monday_start  = input.int(6,  "Monday Start Hour (GMT)",             group=grp_sess, minval=0, maxval=23, tooltip="Monday session starts at 06:30 GMT due to weekend gap dynamics.")
japan_end_h   = input.int(6,  "Japan Session End Hour (GMT)",        group=grp_sess, minval=1, maxval=8)

// Candle patterns
use_engulf    = input.bool(true,  "Engulfing Candle",        group=grp_sig)
use_pin       = input.bool(true,  "Pin Bar",                 group=grp_sig)
use_3bar      = input.bool(true,  "3-Bar Reversal",          group=grp_sig)
pin_wick_mult = input.float(2.0,  "Pin Bar — Min Wick:Body", group=grp_sig, minval=1.0, step=0.25)

// HTF bias — EMA for reversal gate
ema_fast_len  = input.int(20, "EMA Fast Length (1H + 4H)",           group=grp_htf, minval=5,  maxval=100, tooltip="Fast EMA length for 1H and 4H bias. Reversal LONG requires fast > slow on both timeframes. Backtest: EMA20.")
ema_slow_len  = input.int(50, "EMA Slow Length (1H + 4H)",           group=grp_htf, minval=10, maxval=200, tooltip="Slow EMA length for 1H and 4H bias. Backtest: EMA50.")

// Display
show_zone_box  = input.bool(true, "Show Open Zone (shaded box)",    group=grp_disp)
show_session   = input.bool(true, "Show London Session Background", group=grp_disp)
show_exit_lvls = input.bool(true, "Show Exit TP/SL Lines",          group=grp_disp, tooltip="Plots the DXY TP and SL levels after an entry signal fires. Lines disappear once the level is hit.")

// ─── SESSION TIMING ──────────────────────────────────────────────────────────
h        = hour(time, "UTC")
m        = minute(time, "UTC")
is_mon   = dayofweek(time, "UTC") == dayofweek.monday
start_min = (is_mon ? monday_start : entry_start_h) * 60 + entry_start_m
curr_min  = h * 60 + m
end_min   = entry_end_h * 60 + entry_end_m
in_sess     = curr_min >= start_min and curr_min <= end_min
rev_end_min = rev_end_h * 60 + rev_end_m
in_rev_sess = curr_min >= start_min and curr_min <= rev_end_min
in_japan = (h == 23 and m >= 45) or (h >= 0 and h < japan_end_h)
is_2345  = h == 23 and m == 45

// ─── DXY OPEN ZONE ───────────────────────────────────────────────────────────
// Zone forms at 23:45 from the gap between prior close and Japan open.
// If gap < zone_min_gap pts, the 23:45 candle body is used instead.
//
// attr_pristine : set ONCE at London open — True if price is >= attr_min_gap pts
//                 outside the near zone edge, confirming Tokyo left the zone intact.
// london_touched: True once any London bar's range touches the near zone edge.
//                 ATTR fires only while london_touched = false (approach phase).
//                 REV fires once london_touched = true (zone has been tested).

var float zone_top      = na
var float zone_bottom   = na
var bool  japan_bull    = false
var bool  zone_pristine = false   // used only for zone colour display
var bool  attr_pristine = false   // set at London open; price >= attr_min_gap from near edge
var bool  london_touched = false  // True once London bar touches near zone edge

// Cooldown tracking
var int last_attr_long_bar  = na
var int last_attr_short_bar = na
var int last_rev_long_bar   = na
var int last_rev_short_bar  = na

if is_2345
    bool  prior_is_line      = math.abs(close[1] - open[1]) * 10000 < 10
    float prior_candle_close = prior_is_line ? close[2] : close[1]
    float japan_open         = open
    float gap_size           = math.abs(prior_candle_close - japan_open) * 10000
    if gap_size >= zone_min_gap
        zone_top    := math.max(prior_candle_close, japan_open)
        zone_bottom := math.min(prior_candle_close, japan_open)
        japan_bull  := japan_open > prior_candle_close
    else
        zone_top    := math.max(japan_open, close)
        zone_bottom := math.min(japan_open, close)
        japan_bull  := close > japan_open
    zone_pristine   := true
    attr_pristine   := false   // evaluated fresh at London open
    london_touched  := false
    last_attr_long_bar  := na
    last_attr_short_bar := na
    last_rev_long_bar   := na
    last_rev_short_bar  := na

// ─── ZONE STATE: attr_pristine at London open, london_touched each bar ────────
london_open_bar = not in_japan and not na(zone_top) and curr_min == start_min

if london_open_bar
    // Set attr_pristine: True if price is >= attr_min_gap pts from near zone edge
    if not japan_bull
        attr_pristine := (zone_bottom - close) * 10000 >= attr_min_gap
    else
        attr_pristine := (close - zone_top) * 10000 >= attr_min_gap
    london_touched := false   // reset: no London touch yet today

// Update london_touched: any London bar whose range reaches the near zone edge
if not in_japan and not london_touched and not na(zone_top)
    if (not japan_bull and high >= zone_bottom) or (japan_bull and low <= zone_top)
        london_touched := true

// zone_pristine: for display only (orange = untouched, grey = tested)
if zone_pristine and not na(zone_top) and not is_2345
    if japan_bull
        if close < zone_bottom
            zone_pristine := false
    else
        if close > zone_top
            zone_pristine := false

// ─── 3-BAR IMPULSIVE APPROACH ────────────────────────────────────────────────
// Net move toward zone over the prior 3 bars. Confirms retracement has momentum.
approach_long  = (close - close[3]) * 10000   // upward toward zone_bottom (not japan_bull)
approach_short = (close[3] - close) * 10000   // downward toward zone_top  (japan_bull)
impulsive_l    = not japan_bull and approach_long  >= attr_approach
impulsive_s    = japan_bull     and approach_short >= attr_approach

// ─── HTF EMA BIAS (1H + 4H) ─ Reversal gate ─────────────────────────────────
// Both 1H and 4H EMA fast > slow required for REV LONG.
// Both 1H and 4H EMA fast < slow required for REV SHORT.
// Attraction trades do NOT use the EMA gate (backtest: no filter needed for ATTR).
_1h_ema_fast = request.security(syminfo.tickerid, "60",  ta.ema(close, ema_fast_len), lookahead=barmerge.lookahead_off)
_1h_ema_slow = request.security(syminfo.tickerid, "60",  ta.ema(close, ema_slow_len), lookahead=barmerge.lookahead_off)
_4h_ema_fast = request.security(syminfo.tickerid, "240", ta.ema(close, ema_fast_len), lookahead=barmerge.lookahead_off)
_4h_ema_slow = request.security(syminfo.tickerid, "240", ta.ema(close, ema_slow_len), lookahead=barmerge.lookahead_off)
rev_bias_bull = _1h_ema_fast > _1h_ema_slow and _4h_ema_fast > _4h_ema_slow
rev_bias_bear = _1h_ema_fast < _1h_ema_slow and _4h_ema_fast < _4h_ema_slow

// ─── CANDLE MEASUREMENTS ─────────────────────────────────────────────────────
body_sz    = math.abs(close - open)
upper_wick = high - math.max(open, close)
lower_wick = math.min(open, close) - low
cndl_range = high - low
is_bull    = close > open
is_bear    = close < open
rev_candle_ok = (body_sz * 10000 >= rev_min_body) and (cndl_range * 10000 >= rev_min_range)

// ─── ENTRY SIGNALS ───────────────────────────────────────────────────────────
bull_engulf   = use_engulf and is_bull and not is_bull[1] and close > open[1] and open < close[1] and body_sz >= body_sz[1] * 0.8
bear_engulf   = use_engulf and is_bear and not is_bear[1] and close < open[1] and open > close[1] and body_sz >= body_sz[1] * 0.8
bull_pin      = use_pin and lower_wick >= body_sz * pin_wick_mult and upper_wick <= body_sz * 1.5 and cndl_range > 0
bear_pin      = use_pin and upper_wick >= body_sz * pin_wick_mult and lower_wick <= body_sz * 1.5 and cndl_range > 0
bar2_range    = math.abs(close[2] - open[2])
indecision    = body_sz[1] <= bar2_range * 0.5
bull_3bar     = use_3bar and close[2] < open[2] and indecision and is_bull and close > open[2]
bear_3bar     = use_3bar and close[2] > open[2] and indecision and is_bear and close < open[2]
bull_sig      = bull_engulf or bull_pin or bull_3bar
bear_sig      = bear_engulf or bear_pin or bear_3bar
bull_sig_name = bull_engulf ? "Engulfing" : bull_pin ? "Pin Bar" : bull_3bar ? "3-Bar Reversal" : "Signal"
bear_sig_name = bear_engulf ? "Engulfing" : bear_pin ? "Pin Bar" : bear_3bar ? "3-Bar Reversal" : "Signal"

// ─── ZONE WIDTH ──────────────────────────────────────────────────────────────
zone_width_pts = not na(zone_top) ? (zone_top - zone_bottom) * 10000 : 0.0

// ─── ATTRACTION TP / REWARD / SL ─────────────────────────────────────────────
// TP = near zone edge + attr_near_buffer (e.g. zone_bottom + 50 pts for long)
// SL = mirrored 1:1 below entry (sl_dist = tp_dist)
// Min reward: TP must be >= attr_min_reward pts above entry close.
float attr_tp_long  = not na(zone_bottom) ? zone_bottom + attr_near_buffer / 10000.0 : na
float attr_tp_short = not na(zone_top)    ? zone_top    - attr_near_buffer / 10000.0 : na

float reward_long   = not na(attr_tp_long)  ? (attr_tp_long  - close) * 10000 : 0.0
float reward_short  = not na(attr_tp_short) ? (close - attr_tp_short) * 10000 : 0.0

float attr_sl_long  = not na(attr_tp_long)  ? close - (attr_tp_long  - close) : na   // 1:1 mirror
float attr_sl_short = not na(attr_tp_short) ? close + (close - attr_tp_short)  : na   // 1:1 mirror

// ─── DISTANCES FOR REVERSAL ───────────────────────────────────────────────────
dist_rev_long  = not na(zone_bottom) ? math.abs(close - zone_bottom) * 10000 : 9999.0
dist_rev_short = not na(zone_top)    ? math.abs(zone_top - close)    * 10000 : 9999.0

// ─── COOLDOWN GATES ──────────────────────────────────────────────────────────
cool_attr_long  = na(last_attr_long_bar)  or bar_index - last_attr_long_bar  >= cooldown_bars
cool_attr_short = na(last_attr_short_bar) or bar_index - last_attr_short_bar >= cooldown_bars
cool_rev_long   = na(last_rev_long_bar)   or bar_index - last_rev_long_bar   >= cooldown_bars
cool_rev_short  = na(last_rev_short_bar)  or bar_index - last_rev_short_bar  >= cooldown_bars

// ─── ATTRACTION CONDITIONS ───────────────────────────────────────────────────
// Fires DURING the London approach, BEFORE the zone is first touched.
//   attr_pristine    : zone survived Tokyo with >= attr_min_gap pts separation
//   not london_touched: zone not yet touched this session
//   impulsive approach: net 3-bar move toward zone >= attr_approach pts
//   reward_ok        : >= attr_min_reward pts to TP
//   zone width       : >= zone_min_width pts
attr_long  = attr_enabled and attr_pristine and not london_touched and in_sess and not in_japan and not japan_bull and bull_sig and impulsive_l and reward_long  >= attr_min_reward and zone_width_pts >= zone_min_width and cool_attr_long
attr_short = attr_enabled and attr_pristine and not london_touched and in_sess and not in_japan and japan_bull     and bear_sig and impulsive_s and reward_short >= attr_min_reward and zone_width_pts >= zone_min_width and cool_attr_short

// ─── REVERSAL CONDITIONS ─────────────────────────────────────────────────────
// Fires AFTER London has touched the zone (london_touched = true).
// 1H + 4H EMA20 > EMA50 bias aligned with direction.
// Impulsive candle required (body + range thresholds).
rev_long  = rev_enabled and london_touched and in_rev_sess and not in_japan and bull_sig and rev_bias_bull and dist_rev_long  <= rev_max_dist and rev_candle_ok and cool_rev_long
rev_short = rev_enabled and london_touched and in_rev_sess and not in_japan and bear_sig and rev_bias_bear and dist_rev_short <= rev_max_dist and rev_candle_ok and cool_rev_short

// ─── PLOTS ───────────────────────────────────────────────────────────────────
zone_edge_col = zone_pristine ? color.new(color.orange, 20) : color.new(color.gray, 40)
zone_fill_col = zone_pristine ? color.new(color.orange, 80) : color.new(color.gray, 85)

p_top = plot(not na(zone_top)    and show_zone_box ? zone_top    : na, "Zone Top",    color=zone_edge_col, linewidth=2)
p_bot = plot(not na(zone_bottom) and show_zone_box ? zone_bottom : na, "Zone Bottom", color=zone_edge_col, linewidth=2)
fill(p_top, p_bot, color=zone_fill_col, title="Open Zone Fill")

bgcolor(show_session and in_sess ? color.new(color.blue, 93) : na, title="London Session")

// ─── LABELS ──────────────────────────────────────────────────────────────────
lbl_pad = math.max(cndl_range, nz(zone_top, close) * 0.0003)

if attr_long
    float rr_pts = reward_long
    label.new(bar_index, low - lbl_pad,
        "ATTRACTION LONG\n" + bull_sig_name +
        "  |  " + str.tostring(math.round(rr_pts)) + " pts to TP\n" +
        "TP: " + str.tostring(attr_tp_long, "#.####") + " (zone near edge +50 pts)\n" +
        "SL: " + str.tostring(attr_sl_long, "#.####") + " (1:1 mirror)\n" +
        "Approach: " + str.tostring(math.round(approach_long)) + " pts",
        color=color.new(color.green, 5), textcolor=color.white,
        style=label.style_label_up, size=size.normal)
    last_attr_long_bar := bar_index

if attr_short
    float rr_pts = reward_short
    label.new(bar_index, high + lbl_pad,
        "ATTRACTION SHORT\n" + bear_sig_name +
        "  |  " + str.tostring(math.round(rr_pts)) + " pts to TP\n" +
        "TP: " + str.tostring(attr_tp_short, "#.####") + " (zone near edge -50 pts)\n" +
        "SL: " + str.tostring(attr_sl_short, "#.####") + " (1:1 mirror)\n" +
        "Approach: " + str.tostring(math.round(approach_short)) + " pts",
        color=color.new(color.red, 5), textcolor=color.white,
        style=label.style_label_down, size=size.normal)
    last_attr_short_bar := bar_index

if rev_long
    float sl_dist = math.max(close - zone_bottom, rev_min_sl / 10000.0)
    float tp_lvl  = close + sl_dist
    float sl_lvl  = close - sl_dist
    label.new(bar_index, low - lbl_pad,
        "REVERSAL LONG\n" + bull_sig_name + "  |  Zone tested — acts as support\n" +
        "Zone: " + str.tostring(zone_bottom, "#.####") + " – " + str.tostring(zone_top, "#.####") + "\n" +
        "TP: " + str.tostring(tp_lvl, "#.####") + "  SL: " + str.tostring(sl_lvl, "#.####") + " (1:1)\n" +
        "1H/4H EMA bias: bullish",
        color=color.new(color.teal, 5), textcolor=color.white,
        style=label.style_label_up, size=size.normal)
    last_rev_long_bar := bar_index

if rev_short
    float sl_dist = math.max(zone_top - close, rev_min_sl / 10000.0)
    float tp_lvl  = close - sl_dist
    float sl_lvl  = close + sl_dist
    label.new(bar_index, high + lbl_pad,
        "REVERSAL SHORT\n" + bear_sig_name + "  |  Zone tested — acts as resistance\n" +
        "Zone: " + str.tostring(zone_bottom, "#.####") + " – " + str.tostring(zone_top, "#.####") + "\n" +
        "TP: " + str.tostring(tp_lvl, "#.####") + "  SL: " + str.tostring(sl_lvl, "#.####") + " (1:1)\n" +
        "1H/4H EMA bias: bearish",
        color=color.new(color.purple, 5), textcolor=color.white,
        style=label.style_label_down, size=size.normal)
    last_rev_short_bar := bar_index

// ─── ENTRY ALERTS ────────────────────────────────────────────────────────────
alertcondition(attr_long,  title="DXY Attraction LONG",  message="DXY ATTRACTION LONG\nZone pristine at London open. Impulsive approach in progress.\nTP: zone_bottom + 50 pts (near edge) | SL: 1:1 mirror\nGo LONG: USDCAD, USDJPY | Go SHORT: EURUSD, XAUUSD\nZone bottom: {{plot_1}} | Price: {{close}} | {{time}}")
alertcondition(attr_short, title="DXY Attraction SHORT", message="DXY ATTRACTION SHORT\nZone pristine at London open. Impulsive approach in progress.\nTP: zone_top - 50 pts (near edge) | SL: 1:1 mirror\nGo SHORT: USDCAD, USDJPY | Go LONG: EURUSD, XAUUSD\nZone top: {{plot_0}} | Price: {{close}} | {{time}}")
alertcondition(rev_long,   title="DXY Reversal LONG",   message="DXY REVERSAL LONG\nZone tested — acting as support. 1H + 4H EMA bullish.\nGo LONG: USDCAD, USDJPY | Go SHORT: EURUSD, XAUUSD\nZone bottom: {{plot_1}} | Price: {{close}} | {{time}}")
alertcondition(rev_short,  title="DXY Reversal SHORT",  message="DXY REVERSAL SHORT\nZone tested — acting as resistance. 1H + 4H EMA bearish.\nGo SHORT: USDCAD, USDJPY | Go LONG: EURUSD, XAUUSD\nZone top: {{plot_0}} | Price: {{close}} | {{time}}")
alertcondition(attr_long or attr_short or rev_long or rev_short, title="DXY Trade Alert - Any Setup", message="DXY TRADE ALERT — Setup detected. Check zone status and direction.\nPrice: {{close}} | {{time}}")

// ─── EXIT TRACKING ────────────────────────────────────────────────────────────
// Stores DXY TP and SL at the moment each entry signal fires.
// Monitors price on every subsequent bar and alerts when either level is crossed.
// Exit all open pair positions (EURUSD, USDJPY, USDCAD, XAUUSD) when alerted.
// If a new entry fires before the previous trade resolves, levels are updated
// to the newest signal — in practice only one zone trade is open at a time.

var float exit_tp_lvl    = na
var float exit_sl_lvl    = na
var bool  exit_tracking  = false
var bool  exit_is_long   = true
var int   exit_entry_bar = -1

// Register TP/SL when an entry signal fires
if attr_long
    exit_tp_lvl    := attr_tp_long
    exit_sl_lvl    := attr_sl_long
    exit_tracking  := true
    exit_is_long   := true
    exit_entry_bar := bar_index

if attr_short
    exit_tp_lvl    := attr_tp_short
    exit_sl_lvl    := attr_sl_short
    exit_tracking  := true
    exit_is_long   := false
    exit_entry_bar := bar_index

if rev_long
    float _rsd    = math.max(close - zone_bottom, rev_min_sl / 10000.0)
    exit_tp_lvl   := close + _rsd
    exit_sl_lvl   := close - _rsd
    exit_tracking := true
    exit_is_long  := true
    exit_entry_bar := bar_index

if rev_short
    float _rsd    = math.max(zone_top - close, rev_min_sl / 10000.0)
    exit_tp_lvl   := close - _rsd
    exit_sl_lvl   := close + _rsd
    exit_tracking := true
    exit_is_long  := false
    exit_entry_bar := bar_index

// Detect TP/SL cross — only on bars after the entry bar
bool _can_exit   = exit_tracking and bar_index > exit_entry_bar
bool dxy_tp_hit  = _can_exit and (exit_is_long ? high >= exit_tp_lvl : low  <= exit_tp_lvl)
bool dxy_sl_hit  = _can_exit and (exit_is_long ? low  <= exit_sl_lvl : high >= exit_sl_lvl)

if dxy_tp_hit or dxy_sl_hit
    exit_tracking := false

// Plot live TP and SL lines while tracking (disappear once hit)
plot(show_exit_lvls and exit_tracking and not na(exit_tp_lvl) ? exit_tp_lvl : na,
    "DXY Exit TP", color=color.new(color.lime, 20), linewidth=1, style=plot.style_linebr)
plot(show_exit_lvls and exit_tracking and not na(exit_sl_lvl) ? exit_sl_lvl : na,
    "DXY Exit SL", color=color.new(color.red,  20), linewidth=1, style=plot.style_linebr)

// Exit labels on chart
if dxy_tp_hit
    label.new(bar_index,
        exit_is_long ? high + lbl_pad : low - lbl_pad,
        "▲ DXY TP HIT\nExit pair positions",
        color=color.new(color.lime, 10), textcolor=color.black,
        style=exit_is_long ? label.style_label_down : label.style_label_up,
        size=size.normal)

if dxy_sl_hit
    label.new(bar_index,
        exit_is_long ? low - lbl_pad : high + lbl_pad,
        "▼ DXY SL HIT\nExit pair positions",
        color=color.new(color.red, 10), textcolor=color.white,
        style=exit_is_long ? label.style_label_up : label.style_label_down,
        size=size.normal)

// ─── EXIT ALERTS ─────────────────────────────────────────────────────────────
alertcondition(dxy_tp_hit,
    title   = "DXY TP Hit — Exit Pairs",
    message = "DXY TP HIT — Exit all pair positions now.\nAttr/Rev LONG signal: close USDJPY / USDCAD longs and EURUSD / XAUUSD shorts.\nAttr/Rev SHORT signal: reverse above.\nDXY: {{close}} | TP was: {{plot_3}} | {{time}}")

alertcondition(dxy_sl_hit,
    title   = "DXY SL Hit — Exit Pairs",
    message = "DXY SL HIT — Exit all pair positions now.\nAttr/Rev LONG signal: close USDJPY / USDCAD longs and EURUSD / XAUUSD shorts.\nAttr/Rev SHORT signal: reverse above.\nDXY: {{close}} | SL was: {{plot_4}} | {{time}}")

alertcondition(dxy_tp_hit or dxy_sl_hit,
    title   = "DXY Exit — TP or SL",
    message = "DXY EXIT — Close all pair positions now.\nDXY has hit its TP or SL level. Exit EURUSD, USDJPY, USDCAD, XAUUSD.\nDXY: {{close}} | {{time}}")
