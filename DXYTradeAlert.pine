//@version=6
indicator("DXY Trade Alert", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=100)

// ─── INPUTS ──────────────────────────────────────────────────────────────────
grp_zone = "Signal Parameters"
grp_sess = "Session Window (GMT)"
grp_sig  = "Entry Signals"
grp_htf  = "HTF Bias (BB Regime)"
grp_disp = "Display"

// London Open Attraction (LON_ATTR)
lon_attr_enabled   = input.bool(true,  "Enable London Open Attraction (LON_ATTR)",            group=grp_zone, tooltip="Pin bar attraction trade toward the London session open level. Long: price >= min pts below open, pristine (never crossed above open this session), bull pin bar. Short: price >= min pts above open, pristine (never crossed below open), bear pin bar. TP = London open. SL = structural stop (prior session extreme).")
lon_attr_min_long  = input.int(1000,   "LON_ATTR — Min Distance Long (pts below open)",       group=grp_zone, minval=50, step=10,  tooltip="Long fires when DXY close is at least this many pts below London open. Backtest optimum: 1000 pts (61.9% WR, +10R net over 32 months).")
lon_attr_min_short = input.int(1000,   "LON_ATTR — Min Distance Short (pts above open)",      group=grp_zone, minval=50, step=10,  tooltip="Short fires when DXY close is at least this many pts above London open. Backtest optimum: 1000 pts (53.7% WR, +3R net over 32 months).")

// Gap Rejection (Attraction trades removed — managed manually)
attr_enabled        = input.bool(true,  "Enable Gap Rejection Alerts",                       group=grp_zone)
attr_min_gap        = input.int(75,     "Attraction — Min Gap at Tokyo Open (pts)",           group=grp_zone, minval=10,  step=25,  tooltip="Gap between the 23:15 UTC bar close (candle prior to the 23:30 phantom/session-closing candle) and the 23:45 UTC Tokyo open. Fallback: body of the 23:45 candle if no gap. Backtest optimum: 75 pts (+77.9R pair net R at 25 pts vs +51.1R at 150 pts; 75 pts balances signal count with meaningful gap size).")
attr_min_reward     = input.int(100,    "Attraction — Min Reward to TP (pts)",                group=grp_zone, minval=50,  step=25,  tooltip="Minimum distance (pts) from entry close to TP at the time of the signal.")
attr_near_buf       = input.int(50,     "Attraction — Near-Edge TP Buffer (pts)",             group=grp_zone, minval=0,   step=10,  tooltip="When near-edge TP mode is on, TP is set just past the London open price by this many pts. Reduces exposure to full gap-fill failure.")
attr_use_near_tp    = input.bool(true,  "Attraction — Use Near-Edge TP (vs full gap fill)",   group=grp_zone,                      tooltip="On: TP = London open ± near buffer. Off: TP = prior session close (full gap fill).")
attr_max_prev_range = input.int(8000,   "Attraction — Max Prior Session Range (pts)",         group=grp_zone, minval=500, step=500, tooltip="Skip attraction if prior session DXY range exceeded this. Median DXY daily range ~4800 pts; 8000 passes ~85% of days. Reduces to ~50% at 5000 pts.")

// Reversal
rev_enabled    = input.bool(true, "Enable Reversal Trade Alerts",                             group=grp_zone)
rev_proximity  = input.int(250,   "Reversal — Max Distance from Opening Level (pts)",         group=grp_zone, minval=25,  step=25,  tooltip="Reversal entry fires when price is within this many pts of the London session opening price. Backtest optimum: 250 pts (+69.4R pair net R, 56.8% WR). Wider than original 150 pts captures early approach entries while price is still moving toward the open level.")
rev_min_move   = input.int(400,   "Reversal — Min Move Away from Opening (pts)",              group=grp_zone, minval=25,  step=25,  tooltip="Price must have moved at least this many pts away from the London open before a reversal is valid. Backtest optimum: 400 pts (68.2% WR, +55.9R pair net R vs 54.9% WR at 100 pts). Larger prior move = genuine reversal, not noise.")
struct_sl_buf  = input.int(50,    "Reversal — Structural SL Buffer (pts)",                    group=grp_zone, minval=0,   step=10,  tooltip="Buffer added beyond the prior session high/low for the structural stop. Prevents stop being triggered by identical price touching the prior extreme.")
max_sl_pts     = input.int(3000,  "Reversal — Max SL Distance (pts)",                         group=grp_zone, minval=500, step=250, tooltip="Hard cap on SL distance. If prior session range is very large, SL is capped at this distance from entry. Brice/Ash sweet spot: 1500–2600 pts.")

// Session
entry_start_h = input.int(7,  "REV Entry Start Hour (GMT)",         group=grp_sess, minval=0, maxval=23, tooltip="London open — start of REV entry window. 07:00 GMT on Tue-Fri.")
entry_start_m = input.int(0,  "REV Entry Start Minute (GMT)",       group=grp_sess, minval=0, maxval=59)
attr_start_h  = input.int(6,  "ATTR Entry Start Hour (GMT)",        group=grp_sess, minval=0, maxval=23, tooltip="ATTR entry window opens 1 hour before London on Tue-Fri (Ash's rule: 06:00 GMT). Allows catching gap-fill moves that begin before London open. Monday uses the Monday start time.")
attr_start_m  = input.int(0,  "ATTR Entry Start Minute (GMT)",      group=grp_sess, minval=0, maxval=59)
entry_end_h   = input.int(19, "Entry End Hour (GMT)",               group=grp_sess, minval=0, maxval=23)
entry_end_m   = input.int(30, "Entry End Minute (GMT)",             group=grp_sess, minval=0, maxval=59)
rev_end_h     = input.int(12, "Reversal — Entry End Hour (GMT)",    group=grp_sess, minval=6, maxval=19, tooltip="Reversals fire only during London morning session. Brice/Ash: primary window 07:00–12:00 GMT.")
rev_end_m     = input.int(0,  "Reversal — Entry End Min (GMT)",     group=grp_sess, minval=0, maxval=59)
monday_start  = input.int(6,  "Monday Start Hour (GMT)",            group=grp_sess, minval=0, maxval=23, tooltip="Monday session starts at 06:30 GMT. Applies to both REV and ATTR.")
japan_end_h   = input.int(6,  "Japan Session End Hour (GMT)",       group=grp_sess, minval=1, maxval=8)
lon_attr_end_h= input.int(18, "LON_ATTR — Entry End Hour (GMT)",    group=grp_sess, minval=7, maxval=22, tooltip="LON_ATTR entries close at this hour UTC. Default 18:00 — after this, London open reversals are less reliable.")

// Candle patterns
use_engulf    = input.bool(true,  "Engulfing Candle",                group=grp_sig)
use_pin       = input.bool(true,  "Pin Bar (directional)",           group=grp_sig, tooltip="Bullish pin bar (long lower wick) only for LONG entries. Bearish pin bar (long upper wick) only for SHORT entries. Direction comes from the wick, not candle colour.")
use_3bar      = input.bool(true,  "3-Bar Reversal",                  group=grp_sig)
pin_wick_mult = input.float(2.0,  "Pin Bar — Min Wick:Body",         group=grp_sig, minval=1.0, step=0.25)

// HTF BB Regime (replaces EMA cross)
bb_period     = input.int(20,    "BB Period",                        group=grp_htf, minval=5,  maxval=50,  tooltip="Bollinger Band MA period. Used on 1H timeframe (REV direction filter — expanding + slope direction) and 4H timeframe (ATTR flat-market gate — must be non-expanding for ATTR to fire). Standard: 20.")
bb_std_mult   = input.float(2.0, "BB Std Dev Multiplier",           group=grp_htf, minval=0.5, step=0.25, tooltip="Standard deviations for BB width. Standard: 2.0.")
bb_lookback   = input.int(20,    "BB Width Lookback (flat detection)", group=grp_htf, minval=5, maxval=50, tooltip="Bars to average BB width over for expansion detection. If current width > this average → expanding (trending). If below → flat (consolidating).")

// Display
show_open_lvl  = input.bool(true, "Show London Opening Level",       group=grp_disp, tooltip="Horizontal line at today's London session open price. Primary reference level for REV entries.")
show_gap_zone  = input.bool(true, "Show DXY Gap Zone (ATTR)",        group=grp_disp, tooltip="Draws the Tokyo open gap zone — the area between the 23:45 UTC open and the 23:15 reference close. Green = gap down (ATTR LONG possible). Red = gap up (ATTR SHORT possible). Fades to grey once gap is filled. This is the 'pristine' zone: trades are only taken while price has not yet crossed back through the zone.")
show_prev_hl   = input.bool(true, "Show Prior Day High/Low",         group=grp_disp, tooltip="Dashed lines at prior calendar day's high and low. These are used as structural SL reference levels.")
show_session   = input.bool(true, "Show London Session Background",  group=grp_disp)
show_lon_zone  = input.bool(true, "Show London Open Zone (LON_ATTR)", group=grp_disp, tooltip="Yellow box spanning the body of the London open candle — the LON_ATTR pristine zone (zone_bot to zone_top). Yellow = zone intact (pristine). Grey = zone violated (a candle has closed through zone_top or zone_bot).")
show_exit_lvls = input.bool(true, "Show Exit TP/SL Lines",           group=grp_disp)

// ─── SESSION TIMING ──────────────────────────────────────────────────────────
h        = hour(time, "UTC")
m        = minute(time, "UTC")
is_mon   = dayofweek(time, "UTC") == dayofweek.monday
mon_min    = monday_start * 60 + 30
curr_min   = h * 60 + m
end_min    = entry_end_h   * 60 + entry_end_m
rev_end_min= rev_end_h     * 60 + rev_end_m
rev_start_min  = is_mon ? mon_min : entry_start_h * 60 + entry_start_m   // REV: from London open
attr_start_min = is_mon ? mon_min : attr_start_h  * 60 + attr_start_m    // ATTR: 1hr before London
in_sess          = curr_min >= attr_start_min and curr_min <= end_min           // broadest window (ATTR)
in_rev_sess      = curr_min >= rev_start_min  and curr_min <= rev_end_min
in_japan         = (h == 23 and m >= 45) or (h >= 0 and h < japan_end_h)
lon_attr_end_min = lon_attr_end_h * 60
in_lon_attr_sess = curr_min > rev_start_min and curr_min <= lon_attr_end_min   // strictly after London open

// London open bar: 07:00 UTC (Tue–Fri) or 06:30 UTC (Monday)
is_london_open_bar = not in_japan and
     ((not is_mon and curr_min == entry_start_h * 60 + entry_start_m) or
      (is_mon      and curr_min == monday_start  * 60 + 30))

// ─── PRIOR DAY HIGH / LOW (structural SL reference) ─────────────────────────
// Tracks rolling intraday H/L and hands off to pd_high/pd_low at each new UTC day.
var float today_high = na
var float today_low  = na
var float pd_high    = na   // prior calendar day high
var float pd_low     = na   // prior calendar day low
var float pd_range   = 0.0  // prior calendar day range (pts)

bool is_new_day = not na(time) and ta.change(dayofmonth(time, "UTC")) != 0

if is_new_day
    if not na(today_high)
        pd_high  := today_high
        pd_low   := today_low
        pd_range := (today_high - today_low) * 10000
    today_high := high
    today_low  := low
else
    today_high := na(today_high) ? high : math.max(today_high, high)
    today_low  := na(today_low)  ? low  : math.min(today_low,  low)

// ─── LONDON OPEN LEVEL ───────────────────────────────────────────────────────
// london_open_price : OPEN of the first London bar each day (primary REV level)

var float london_open_price  = na
var float max_move_up        = 0.0   // max pts ABOVE london_open_price this session (used by REV)
var float max_move_down      = 0.0   // max pts BELOW london_open_price this session (used by REV)
var bool  lon_attr_traded    = false  // one LON_ATTR signal per session
// LON_ATTR pristine zone — body of the first London session candle
var float lon_zone_top       = na    // body top  = math.max(open, close) of London open bar
var float lon_zone_bot       = na    // body bot  = math.min(open, close) of London open bar
var bool  lon_pristine_long  = true  // false once any candle open/close >= zone top
var bool  lon_pristine_short = true  // false once any candle open/close <= zone bot
var box   lon_zone_box       = na    // yellow box: body of London open candle, greys out when zone violated

if is_london_open_bar
    london_open_price  := open
    max_move_up        := 0.0
    max_move_down      := 0.0
    lon_attr_traded    := false
    lon_zone_top       := math.max(open, close)
    lon_zone_bot       := math.min(open, close)
    lon_pristine_long  := true
    lon_pristine_short := true
    if show_lon_zone
        box.delete(lon_zone_box)
        lon_zone_box := box.new(bar_index, lon_zone_top, bar_index + 1, lon_zone_bot,
            bgcolor=color.new(color.yellow, 75), border_color=color.new(color.yellow, 40),
            border_width=1, extend=extend.none)

// ─── TOKYO OPEN ATTR GAP (23:45 UTC) ─────────────────────────────────────────
// Gap = 23:45 open vs 23:15 close (the candle prior to the 23:30 phantom/
// session-closing candle).  Fallback: body of the 23:45 candle itself.
// attr_gap_pts  : +ve = Tokyo opened ABOVE reference (gap up → ATTR SHORT to fill)
//                -ve = Tokyo opened BELOW reference (gap down → ATTR LONG to fill)
// attr_gap_target: the reference close price — gap fill TP level

bool  is_tokyo_open = h == 23 and m == 45

var float attr_gap_target  = na
var float attr_gap_pts     = 0.0
var float attr_tokyo_open  = na   // 23:45 open price — upper/lower bound of gap zone
var bool  attr_traded      = false
var bool  attr_gap_touched = false  // latches true once price crosses the gap target this
                                    // session — prevents re-entry if price retreats back

if is_tokyo_open
    attr_tokyo_open  := open
    float raw_gap = (open - close[2]) * 10000   // 23:45 open vs 23:15 close
    if math.abs(raw_gap) >= 10
        attr_gap_pts    := raw_gap
        attr_gap_target := close[2]             // gap-fill target = 23:15 close
    else
        // Fallback: use body of 23:45 candle
        attr_gap_pts    := (close - open) * 10000
        attr_gap_target := open                 // target = return to 23:45 open
    attr_traded      := false                   // reset for new session
    attr_gap_touched := false                   // zone is fresh/pristine at Tokyo open

// Latch: once the gap target is reached, zone is permanently filled for this session
if not na(attr_gap_target)
    if attr_gap_pts < 0 and close >= attr_gap_target    // gap-down: price reached target
        attr_gap_touched := true
    else if attr_gap_pts > 0 and close <= attr_gap_target  // gap-up: price reached target
        attr_gap_touched := true

// Update max move from opening each bar (used by REV conditions)
if not na(london_open_price) and not in_japan
    float above = (close - london_open_price) * 10000
    if above > 0
        max_move_up   := math.max(max_move_up,    above)
    else if above < 0
        max_move_down := math.max(max_move_down, -above)

// LON_ATTR pristine zone violation tracking
// Once any candle's open or close touches/crosses the zone, pristine is lost for that direction.
// Japan session candles and the London open bar itself are excluded.
if not in_japan and not is_london_open_bar and not na(lon_zone_top)
    if open >= lon_zone_top or close >= lon_zone_top
        lon_pristine_long  := false   // zone top breached — no longer pristine for LONG
    if open <= lon_zone_bot or close <= lon_zone_bot
        lon_pristine_short := false   // zone bot breached — no longer pristine for SHORT

// LON_ATTR zone box: extend right edge each bar and update colour to reflect pristine state
// Yellow = at least one direction still pristine; grey = zone fully violated both ways
if show_lon_zone and not na(lon_zone_box)
    bool _any_pristine = lon_pristine_long or lon_pristine_short
    box.set_right(lon_zone_box, bar_index + 1)
    box.set_bgcolor(lon_zone_box,       _any_pristine ? color.new(color.yellow, 75) : color.new(color.gray, 82))
    box.set_border_color(lon_zone_box,  _any_pristine ? color.new(color.yellow, 40) : color.new(color.gray, 60))

// ─── HTF BB REGIME (replaces EMA20/50 cross) ─────────────────────────────────
// Regime values:  +1 = bands EXPANDING, MA sloping UP   → valid for REV LONG
//                 -1 = bands EXPANDING, MA sloping DOWN  → valid for REV SHORT
//                  0 = bands FLAT / contracting          → skip REV; ATTR allowed

// 1H Bollinger Band regime
_1h_bb_basis  = request.security(syminfo.tickerid, "60",  ta.sma(close, bb_period),                                         lookahead=barmerge.lookahead_off)
_1h_bb_basis3 = request.security(syminfo.tickerid, "60",  ta.sma(close, bb_period)[3],                                      lookahead=barmerge.lookahead_off)
_1h_bb_width  = request.security(syminfo.tickerid, "60",  ta.stdev(close, bb_period) * bb_std_mult * 2.0,                   lookahead=barmerge.lookahead_off)
_1h_width_avg = request.security(syminfo.tickerid, "60",  ta.sma(ta.stdev(close, bb_period) * bb_std_mult * 2.0, bb_lookback), lookahead=barmerge.lookahead_off)
_1h_expanding = _1h_bb_width > _1h_width_avg
_1h_slope_up  = _1h_bb_basis > _1h_bb_basis3
bb_1h = _1h_expanding ? (_1h_slope_up ? 1 : -1) : 0

// 4H Bollinger Band regime
_4h_bb_basis  = request.security(syminfo.tickerid, "240", ta.sma(close, bb_period),                                         lookahead=barmerge.lookahead_off)
_4h_bb_basis3 = request.security(syminfo.tickerid, "240", ta.sma(close, bb_period)[3],                                      lookahead=barmerge.lookahead_off)
_4h_bb_width  = request.security(syminfo.tickerid, "240", ta.stdev(close, bb_period) * bb_std_mult * 2.0,                   lookahead=barmerge.lookahead_off)
_4h_width_avg = request.security(syminfo.tickerid, "240", ta.sma(ta.stdev(close, bb_period) * bb_std_mult * 2.0, bb_lookback), lookahead=barmerge.lookahead_off)
_4h_expanding = _4h_bb_width > _4h_width_avg
_4h_slope_up  = _4h_bb_basis > _4h_bb_basis3
bb_4h = _4h_expanding ? (_4h_slope_up ? 1 : -1) : 0

// ─── CANDLE MEASUREMENTS ─────────────────────────────────────────────────────
body_sz    = math.abs(close - open)
body_top   = math.max(open, close)
body_bot   = math.min(open, close)
upper_wick = high - body_top
lower_wick = body_bot - low
cndl_range = high - low

// ─── ENTRY SIGNALS (improved directional pin bars) ───────────────────────────
// Pin bars are SHAPE-based, not colour-based:
//   Bullish pin : long LOWER wick (price rejected lows)  → valid for LONG entries only
//   Bearish pin : long UPPER wick (price rejected highs) → valid for SHORT entries only
bull_engulf = use_engulf and close > open and not (close[1] > open[1]) and close > open[1] and open < close[1] and body_sz >= body_sz[1] * 0.8
bear_engulf = use_engulf and close < open and not (close[1] < open[1]) and close < open[1] and open > close[1] and body_sz >= body_sz[1] * 0.8
bull_pin    = use_pin and lower_wick >= body_sz * pin_wick_mult and lower_wick >= upper_wick * 1.5 and cndl_range > 0
bear_pin    = use_pin and upper_wick >= body_sz * pin_wick_mult and upper_wick >= lower_wick * 1.5 and cndl_range > 0
bar2_range  = math.abs(close[2] - open[2])
indecision  = body_sz[1] <= bar2_range * 0.5
bull_3bar   = use_3bar and close[2] < open[2] and indecision and close > open and close > open[2]
bear_3bar   = use_3bar and close[2] > open[2] and indecision and close < open and close < open[2]
// Raw signals before mutual-exclusivity check
bool _bull_raw = bull_engulf or bull_pin or bull_3bar
bool _bear_raw = bear_engulf or bear_pin or bear_3bar
// If both fire on the same bar, body direction is the tiebreaker:
//   bullish body (close > open) → keep bull, drop bear
//   bearish body (close < open) → keep bear, drop bull
//   doji (close == open)        → suppress both (too ambiguous)
bool _both     = _bull_raw and _bear_raw
bull_sig    = _bull_raw and not (_both and close <= open)
bear_sig    = _bear_raw and not (_both and close >= open)
bull_sig_name = bull_engulf ? "Engulfing" : bull_pin ? "Bull Pin Bar" : bull_3bar ? "3-Bar Reversal" : "Signal"
bear_sig_name = bear_engulf ? "Engulfing" : bear_pin ? "Bear Pin Bar" : bear_3bar ? "3-Bar Reversal" : "Signal"

// ─── LON_ATTR PIN BAR (always active — independent of use_pin input) ──────────
// LON_ATTR uses pin bars only. Computed separately so the use_pin toggle does
// not affect LON_ATTR entries.
la_bull_pin_r = lower_wick >= body_sz * pin_wick_mult and lower_wick >= upper_wick * 1.5 and cndl_range > 0
la_bear_pin_r = upper_wick >= body_sz * pin_wick_mult and upper_wick >= lower_wick * 1.5 and cndl_range > 0
bool _la_pb   = la_bull_pin_r and la_bear_pin_r
la_bull_pin   = la_bull_pin_r and not (_la_pb and close <= open)   // body tiebreaker
la_bear_pin   = la_bear_pin_r and not (_la_pb and close >= open)

// ─── DISTANCE FROM OPENING LEVEL ─────────────────────────────────────────────
float dist_from_open = not na(london_open_price) ? (close - london_open_price) * 10000 : na
bool  at_open_level  = not na(dist_from_open) and math.abs(dist_from_open) <= rev_proximity

// ─── REVERSAL TP / SL (structural) ───────────────────────────────────────────
// SL = prior day low − buffer (long) or prior day high + buffer (short), capped at max_sl_pts
float rev_long_raw_sl  = na(pd_low)  ? close - max_sl_pts / 10000.0 : pd_low  - struct_sl_buf / 10000.0
float rev_long_sl      = math.max(rev_long_raw_sl,  close - max_sl_pts / 10000.0)
float rev_long_sl_d    = close - rev_long_sl
float rev_long_tp      = close + rev_long_sl_d

float rev_short_raw_sl = na(pd_high) ? close + max_sl_pts / 10000.0 : pd_high + struct_sl_buf / 10000.0
float rev_short_sl     = math.min(rev_short_raw_sl, close + max_sl_pts / 10000.0)
float rev_short_sl_d   = rev_short_sl - close
float rev_short_tp     = close - rev_short_sl_d

// ─── ATTRACTION TP / SL ───────────────────────────────────────────────────────
// ATTR LONG : gap down → fill up → TP = attr_gap_target (Tokyo 23:15 reference)
// ATTR SHORT: gap up   → fill dn → TP = attr_gap_target
// Near-edge TP stops just short of the full gap-fill target
float attr_long_tp  = attr_use_near_tp ? attr_gap_target - attr_near_buf / 10000.0 : attr_gap_target
float attr_short_tp = attr_use_near_tp ? attr_gap_target + attr_near_buf / 10000.0 : attr_gap_target
float attr_long_reward  = not na(attr_long_tp)  ? (attr_long_tp  - close) * 10000 : 0.0
float attr_short_reward = not na(attr_short_tp) ? (close - attr_short_tp) * 10000 : 0.0
float attr_long_sl_d    = not na(attr_long_tp)  ? attr_long_tp  - close : na
float attr_short_sl_d   = not na(attr_short_tp) ? close - attr_short_tp : na
float attr_long_sl      = not na(attr_long_sl_d)  ? close - attr_long_sl_d  : na   // 1:1 mirror
float attr_short_sl     = not na(attr_short_sl_d) ? close + attr_short_sl_d : na   // 1:1 mirror

// ─── LON_ATTR TP / SL (1:1 R:R) ─────────────────────────────────────────────
// TP  = lon_zone_bot (near edge of the London session open candle body)
//         LONG  : zone_bot is the nearest body edge above a below-open entry
//         SHORT : zone_bot is the far body edge below an above-open entry
// SL  = 1:1 mirror of TP distance on the opposite side of entry
//   Long : entry BELOW zone_bot → sl_d = zone_bot − close (> 0 required) → SL = close − sl_d
//   Short: entry ABOVE zone_bot → sl_d = close − zone_bot (> 0 required) → SL = close + sl_d
// Condition guard (sl_d > 0) ensures TP is in the correct direction before firing.
float lon_attr_long_tp    = lon_zone_bot
float lon_attr_long_sl_d  = lon_zone_bot - close               // TP distance (must be > 0)
float lon_attr_long_sl    = close - lon_attr_long_sl_d         // 1:1 mirror below entry
float lon_attr_short_tp   = lon_zone_bot
float lon_attr_short_sl_d = close - lon_zone_bot               // TP distance (must be > 0)
float lon_attr_short_sl   = close + lon_attr_short_sl_d        // 1:1 mirror above entry

// ─── REVERSAL CONDITIONS ─────────────────────────────────────────────────────
// Price moved away from London open then RETURNED to it.
// 1H BB must be expanding in trade direction.
// Confirmation candle AT the opening level.
rev_long  = (rev_enabled and not na(london_open_price) and
    in_rev_sess and not in_japan and
    max_move_down >= rev_min_move and
    at_open_level and
    bull_sig and
    bb_1h == 1 and
    not na(pd_low) and
    rev_long_sl_d > 0)

rev_short = (rev_enabled and not na(london_open_price) and
    in_rev_sess and not in_japan and
    max_move_up >= rev_min_move and
    at_open_level and
    bear_sig and
    bb_1h == -1 and
    not na(pd_high) and
    rev_short_sl_d > 0)

// ─── GAP REJECTION CONDITIONS ─────────────────────────────────────────────────
// Gap was already filled (attr_gap_touched=true) but price has pulled back.
// Same filters as ATTR — only the zone-state latch differs.
gap_rej_long  = (attr_enabled and not na(attr_gap_target) and not attr_traded and attr_gap_touched and
    in_sess and not in_japan and
    attr_gap_pts < -attr_min_gap and
    close < attr_gap_target and
    pd_range <= attr_max_prev_range and
    bb_4h == 0 and
    bull_sig and
    attr_long_reward >= attr_min_reward and
    not na(attr_long_sl_d) and attr_long_sl_d > 0)

gap_rej_short = (attr_enabled and not na(attr_gap_target) and not attr_traded and attr_gap_touched and
    in_sess and not in_japan and
    attr_gap_pts > attr_min_gap and
    close > attr_gap_target and
    pd_range <= attr_max_prev_range and
    bb_4h == 0 and
    bear_sig and
    attr_short_reward >= attr_min_reward and
    not na(attr_short_sl_d) and attr_short_sl_d > 0)

// Block further gap-window signals once any one has traded this session
if gap_rej_long or gap_rej_short
    attr_traded := true

// ─── LON_ATTR CONDITIONS ─────────────────────────────────────────────────────
// Pristine is detected via max_move_up / max_move_down:
//   max_move_up   == 0  → price has never been above London open this session
//   max_move_down == 0  → price has never been below London open this session
// One signal per session (lon_attr_traded flag). No BB regime filter required.

bool lon_attr_long = (lon_attr_enabled and
    not lon_attr_traded and
    not na(london_open_price) and
    in_lon_attr_sess and not in_japan and
    dist_from_open <= -lon_attr_min_long and   // price >= min_long pts BELOW London open
    lon_pristine_long and                       // pristine: no candle open/close has touched zone top
    lon_attr_long_sl_d > 0 and                 // zone_bot must be above entry (valid TP)
    la_bull_pin)                                // bull pin bar only

bool lon_attr_short = (lon_attr_enabled and
    not lon_attr_traded and
    not na(london_open_price) and
    in_lon_attr_sess and not in_japan and
    dist_from_open >= lon_attr_min_short and   // price >= min_short pts ABOVE London open
    lon_pristine_short and                      // pristine: no candle open/close has touched zone bot
    lon_attr_short_sl_d > 0 and                // zone_bot must be below entry (valid TP)
    la_bear_pin)                                // bear pin bar only

if lon_attr_long or lon_attr_short
    lon_attr_traded := true

// ─── PLOTS ───────────────────────────────────────────────────────────────────

// ─── DXY GAP ZONE (ATTR) ─────────────────────────────────────────────────────
// Shows the Tokyo open gap zone: between the 23:45 open (attr_tokyo_open) and
// the 23:15 reference close (attr_gap_target).
// Green fill = gap down → LONG setup is still "pristine" (gap not yet filled).
// Red fill   = gap up   → SHORT setup is still "pristine" (gap not yet filled).
// Grey fill  = gap has been filled / price crossed back through the zone.
bool _gap_valid  = not na(attr_gap_target) and not na(attr_tokyo_open) and math.abs(attr_gap_pts) >= attr_min_gap
// Pristine = gap valid AND target never yet reached this session
bool _gap_long   = _gap_valid and attr_gap_pts < 0 and not attr_gap_touched   // pristine long
bool _gap_short  = _gap_valid and attr_gap_pts > 0 and not attr_gap_touched   // pristine short
color _zone_col  = _gap_long ? color.new(color.green, 82) : _gap_short ? color.new(color.red, 82) : color.new(color.gray, 70)

p_zone_top = plot(show_gap_zone and _gap_valid ? math.max(attr_gap_target, attr_tokyo_open) : na,
    "Gap Zone Top", color=color.new(color.aqua, 60), linewidth=1, style=plot.style_linebr, display=display.all)
p_zone_bot = plot(show_gap_zone and _gap_valid ? math.min(attr_gap_target, attr_tokyo_open) : na,
    "Gap Zone Bot (Target)", color=color.new(color.aqua, 30), linewidth=2, style=plot.style_linebr, display=display.all)
fill(p_zone_top, p_zone_bot, color=_zone_col, title="ATTR Gap Zone Fill")

// London opening level (horizontal line, resets each day at London open)
plot(show_open_lvl and not na(london_open_price) ? london_open_price : na,
    "London Open Level", color=color.new(color.yellow, 20), linewidth=2, style=plot.style_linebr)

// Prior day high/low reference lines
plot(show_prev_hl and not na(pd_high) ? pd_high : na,
    "Prior Day High", color=color.new(color.red, 40), linewidth=1, style=plot.style_linebr)
plot(show_prev_hl and not na(pd_low) ? pd_low : na,
    "Prior Day Low",  color=color.new(color.green, 40), linewidth=1, style=plot.style_linebr)

bgcolor(show_session and in_sess ? color.new(color.blue, 93) : na, title="London Session")

// BB regime background hint (subtle)
bgcolor(bb_4h == 0 ? color.new(color.orange, 97) : na, title="4H BB Flat (ATTR zone)")

// ─── TP / SL LINE REFERENCES ─────────────────────────────────────────────────
var line tp_line = na
var line sl_line = na

// ─── LABELS ──────────────────────────────────────────────────────────────────
lbl_pad = math.max(cndl_range, nz(london_open_price, close) * 0.0003)

if gap_rej_long
    label.new(bar_index, low - lbl_pad,
        "⚠ CHECK NEWS!\nGAP REJECTION LONG\n" + bull_sig_name +
        "  |  Gap down (filled): " + str.tostring(math.round(math.abs(attr_gap_pts))) + " pts\n" +
        "TP: " + str.tostring(attr_long_tp, "#.####") +
            (attr_use_near_tp ? " (London open + buf)" : " (prior session close)") + "\n" +
        "SL: " + str.tostring(attr_long_sl, "#.####") + " (1:1 mirror)\n" +
        "4H BB: flat  |  Prev range: " + str.tostring(math.round(pd_range)) + " pts",
        color=color.new(color.orange, 5), textcolor=color.white,
        style=label.style_label_up, size=size.normal)
    line.delete(tp_line)
    line.delete(sl_line)
    tp_line := line.new(bar_index, attr_long_tp, bar_index + 1, attr_long_tp,
                        extend=extend.right, color=color.new(color.lime, 0),
                        style=line.style_dashed, width=2)
    sl_line := line.new(bar_index, attr_long_sl, bar_index + 1, attr_long_sl,
                        extend=extend.right, color=color.new(color.red, 0),
                        style=line.style_dashed, width=2)

if gap_rej_short
    label.new(bar_index, high + lbl_pad,
        "⚠ CHECK NEWS!\nGAP REJECTION SHORT\n" + bear_sig_name +
        "  |  Gap up (filled): " + str.tostring(math.round(attr_gap_pts)) + " pts\n" +
        "TP: " + str.tostring(attr_short_tp, "#.####") +
            (attr_use_near_tp ? " (London open - buf)" : " (prior session close)") + "\n" +
        "SL: " + str.tostring(attr_short_sl, "#.####") + " (1:1 mirror)\n" +
        "4H BB: flat  |  Prev range: " + str.tostring(math.round(pd_range)) + " pts",
        color=color.new(color.orange, 5), textcolor=color.white,
        style=label.style_label_down, size=size.normal)
    line.delete(tp_line)
    line.delete(sl_line)
    tp_line := line.new(bar_index, attr_short_tp, bar_index + 1, attr_short_tp,
                        extend=extend.right, color=color.new(color.lime, 0),
                        style=line.style_dashed, width=2)
    sl_line := line.new(bar_index, attr_short_sl, bar_index + 1, attr_short_sl,
                        extend=extend.right, color=color.new(color.red, 0),
                        style=line.style_dashed, width=2)

if rev_long
    label.new(bar_index, low - lbl_pad,
        "REVERSAL LONG\n" + bull_sig_name +
        "  |  Returned to London open after " + str.tostring(math.round(max_move_down)) + " pts down\n" +
        "Opening level: " + str.tostring(london_open_price, "#.####") + "\n" +
        "TP: " + str.tostring(rev_long_tp, "#.####") +
            "  SL: " + str.tostring(rev_long_sl, "#.####") +
            " (" + str.tostring(math.round(rev_long_sl_d * 10000)) + " pts)\n" +
        "1H BB: expanding bullish",
        color=color.new(color.teal, 5), textcolor=color.white,
        style=label.style_label_up, size=size.normal)
    line.delete(tp_line)
    line.delete(sl_line)
    tp_line := line.new(bar_index, rev_long_tp, bar_index + 1, rev_long_tp,
                        extend=extend.right, color=color.new(color.lime, 0),
                        style=line.style_dashed, width=2)
    sl_line := line.new(bar_index, rev_long_sl, bar_index + 1, rev_long_sl,
                        extend=extend.right, color=color.new(color.red, 0),
                        style=line.style_dashed, width=2)

if rev_short
    label.new(bar_index, high + lbl_pad,
        "REVERSAL SHORT\n" + bear_sig_name +
        "  |  Returned to London open after " + str.tostring(math.round(max_move_up)) + " pts up\n" +
        "Opening level: " + str.tostring(london_open_price, "#.####") + "\n" +
        "TP: " + str.tostring(rev_short_tp, "#.####") +
            "  SL: " + str.tostring(rev_short_sl, "#.####") +
            " (" + str.tostring(math.round(rev_short_sl_d * 10000)) + " pts)\n" +
        "1H BB: expanding bearish",
        color=color.new(color.purple, 5), textcolor=color.white,
        style=label.style_label_down, size=size.normal)
    line.delete(tp_line)
    line.delete(sl_line)
    tp_line := line.new(bar_index, rev_short_tp, bar_index + 1, rev_short_tp,
                        extend=extend.right, color=color.new(color.lime, 0),
                        style=line.style_dashed, width=2)
    sl_line := line.new(bar_index, rev_short_sl, bar_index + 1, rev_short_sl,
                        extend=extend.right, color=color.new(color.red, 0),
                        style=line.style_dashed, width=2)

if lon_attr_long
    label.new(bar_index, low - lbl_pad,
        "LON_ATTR LONG (Pin Bar)\n" +
        str.tostring(math.round(-dist_from_open)) + " pts below London open — zone intact\n" +
        "TP: " + str.tostring(lon_attr_long_tp, "#.####") + " (zone near edge)\n" +
        "SL: " + str.tostring(lon_attr_long_sl, "#.####") +
        "  (" + str.tostring(math.round(lon_attr_long_sl_d * 10000)) + " pts, 1:1)\n" +
        "Go LONG: USDCAD, USDJPY  |  Go SHORT: EURUSD, XAUUSD",
        color=color.new(color.navy, 5), textcolor=color.white,
        style=label.style_label_up, size=size.normal)
    line.delete(tp_line)
    line.delete(sl_line)
    tp_line := line.new(bar_index, lon_attr_long_tp, bar_index + 1, lon_attr_long_tp,
                        extend=extend.right, color=color.new(color.lime, 0),
                        style=line.style_dashed, width=2)
    sl_line := line.new(bar_index, lon_attr_long_sl, bar_index + 1, lon_attr_long_sl,
                        extend=extend.right, color=color.new(color.red, 0),
                        style=line.style_dashed, width=2)

if lon_attr_short
    label.new(bar_index, high + lbl_pad,
        "LON_ATTR SHORT (Pin Bar)\n" +
        str.tostring(math.round(dist_from_open)) + " pts above London open — zone intact\n" +
        "TP: " + str.tostring(lon_attr_short_tp, "#.####") + " (zone far edge)\n" +
        "SL: " + str.tostring(lon_attr_short_sl, "#.####") +
        "  (" + str.tostring(math.round(lon_attr_short_sl_d * 10000)) + " pts, 1:1)\n" +
        "Go SHORT: USDCAD, USDJPY  |  Go LONG: EURUSD, XAUUSD",
        color=color.new(color.maroon, 5), textcolor=color.white,
        style=label.style_label_down, size=size.normal)
    line.delete(tp_line)
    line.delete(sl_line)
    tp_line := line.new(bar_index, lon_attr_short_tp, bar_index + 1, lon_attr_short_tp,
                        extend=extend.right, color=color.new(color.lime, 0),
                        style=line.style_dashed, width=2)
    sl_line := line.new(bar_index, lon_attr_short_sl, bar_index + 1, lon_attr_short_sl,
                        extend=extend.right, color=color.new(color.red, 0),
                        style=line.style_dashed, width=2)

// ─── ENTRY ALERTS ────────────────────────────────────────────────────────────
alertcondition(gap_rej_long,   title="DXY Gap Rejection LONG",   message="DXY GAP REJECTION LONG\n⚠ CHECK NEWS!\nGap filled then price pulled back. 4H BB flat. Bullish confirmation candle.\nTP: London open + buffer | SL: 1:1 mirror\nGo LONG: USDCAD, USDJPY | Go SHORT: EURUSD, XAUUSD\nLondon open: {{plot_0}} | Price: {{close}} | {{time}}")
alertcondition(gap_rej_short,  title="DXY Gap Rejection SHORT",  message="DXY GAP REJECTION SHORT\n⚠ CHECK NEWS!\nGap filled then price pulled back. 4H BB flat. Bearish confirmation candle.\nTP: London open - buffer | SL: 1:1 mirror\nGo SHORT: USDCAD, USDJPY | Go LONG: EURUSD, XAUUSD\nLondon open: {{plot_0}} | Price: {{close}} | {{time}}")
alertcondition(rev_long,       title="DXY Reversal LONG",        message="DXY REVERSAL LONG\nPrice returned to London open level. 1H BB expanding bullish.\nStructural SL at prior day low.\nGo LONG: USDCAD, USDJPY | Go SHORT: EURUSD, XAUUSD\nOpening level: {{plot_0}} | Price: {{close}} | {{time}}")
alertcondition(rev_short,      title="DXY Reversal SHORT",       message="DXY REVERSAL SHORT\nPrice returned to London open level. 1H BB expanding bearish.\nStructural SL at prior day high.\nGo SHORT: USDCAD, USDJPY | Go LONG: EURUSD, XAUUSD\nOpening level: {{plot_0}} | Price: {{close}} | {{time}}")
alertcondition(lon_attr_long,  title="DXY LON_ATTR LONG",           message="DXY LON_ATTR LONG (Pin Bar)\nPrice is pristine — zone top never touched this session.\nBull pin bar >= 1000 pts below London open. TP = zone near edge (zone_bot). SL = 1:1 mirror.\nGo LONG: USDCAD, USDJPY | Go SHORT: EURUSD, XAUUSD\nLondon open: {{plot_0}} | Price: {{close}} | {{time}}")
alertcondition(lon_attr_short, title="DXY LON_ATTR SHORT",          message="DXY LON_ATTR SHORT (Pin Bar)\nPrice is pristine — zone bot never touched this session.\nBear pin bar >= 1000 pts above London open. TP = zone far edge (zone_bot). SL = 1:1 mirror.\nGo SHORT: USDCAD, USDJPY | Go LONG: EURUSD, XAUUSD\nLondon open: {{plot_0}} | Price: {{close}} | {{time}}")
alertcondition(gap_rej_long or gap_rej_short or rev_long or rev_short or lon_attr_long or lon_attr_short, title="DXY Trade Alert - Any Setup", message="DXY TRADE ALERT — Setup detected. Check direction and levels.\nPrice: {{close}} | {{time}}")

// ─── EXIT TRACKING ────────────────────────────────────────────────────────────
var float exit_tp_lvl    = na
var float exit_sl_lvl    = na
var bool  exit_tracking  = false
var bool  exit_is_long   = true
var int   exit_entry_bar = -1

// NOTE: exit_tracking is NOT reset at London open. It only clears when TP or SL
// is actually hit. This prevents orphan exit warnings caused by the London open
// reset firing before the TP/SL detection check on the same bar.
// New signals delete and redraw lines themselves, so visual cleanup is handled there.

// Register TP/SL when entry fires
if gap_rej_long
    exit_tp_lvl   := attr_long_tp
    exit_sl_lvl   := attr_long_sl
    exit_tracking := true
    exit_is_long  := true
    exit_entry_bar := bar_index

if gap_rej_short
    exit_tp_lvl   := attr_short_tp
    exit_sl_lvl   := attr_short_sl
    exit_tracking := true
    exit_is_long  := false
    exit_entry_bar := bar_index

if rev_long
    exit_tp_lvl   := rev_long_tp
    exit_sl_lvl   := rev_long_sl
    exit_tracking := true
    exit_is_long  := true
    exit_entry_bar := bar_index

if rev_short
    exit_tp_lvl   := rev_short_tp
    exit_sl_lvl   := rev_short_sl
    exit_tracking := true
    exit_is_long  := false
    exit_entry_bar := bar_index

if lon_attr_long
    exit_tp_lvl    := lon_attr_long_tp
    exit_sl_lvl    := lon_attr_long_sl
    exit_tracking  := true
    exit_is_long   := true
    exit_entry_bar := bar_index

if lon_attr_short
    exit_tp_lvl    := lon_attr_short_tp
    exit_sl_lvl    := lon_attr_short_sl
    exit_tracking  := true
    exit_is_long   := false
    exit_entry_bar := bar_index

// Detect TP/SL cross
bool _can_exit  = exit_tracking and bar_index > exit_entry_bar
bool dxy_tp_hit = _can_exit and (exit_is_long ? high >= exit_tp_lvl : low  <= exit_tp_lvl)
bool dxy_sl_hit = _can_exit and (exit_is_long ? low  <= exit_sl_lvl : high >= exit_sl_lvl)

if dxy_tp_hit or dxy_sl_hit
    exit_tracking := false
    line.delete(tp_line)
    line.delete(sl_line)

// Live TP/SL lines
plot(show_exit_lvls and exit_tracking and not na(exit_tp_lvl) ? exit_tp_lvl : na,
    "DXY Exit TP", color=color.new(color.lime, 20), linewidth=1, style=plot.style_linebr)
plot(show_exit_lvls and exit_tracking and not na(exit_sl_lvl) ? exit_sl_lvl : na,
    "DXY Exit SL", color=color.new(color.red,  20), linewidth=1, style=plot.style_linebr)

if dxy_tp_hit
    label.new(bar_index, exit_is_long ? high + lbl_pad : low - lbl_pad,
        "▲ DXY TP HIT\nExit pair positions",
        color=color.new(color.lime, 10), textcolor=color.black,
        style=exit_is_long ? label.style_label_down : label.style_label_up, size=size.normal)

if dxy_sl_hit
    label.new(bar_index, exit_is_long ? low - lbl_pad : high + lbl_pad,
        "▼ DXY SL HIT\nExit pair positions",
        color=color.new(color.red, 10), textcolor=color.white,
        style=exit_is_long ? label.style_label_up : label.style_label_down, size=size.normal)

// ─── EXIT ALERTS ─────────────────────────────────────────────────────────────
alertcondition(dxy_tp_hit,
    title   = "DXY TP Hit — Exit Pairs",
    message = "DXY TP HIT — Exit all pair positions now.\nLONG signal: close USDJPY/USDCAD longs and EURUSD/XAUUSD shorts.\nSHORT signal: reverse above.\nDXY: {{close}} | {{time}}")
alertcondition(dxy_sl_hit,
    title   = "DXY SL Hit — Exit Pairs",
    message = "DXY SL HIT — Exit all pair positions now.\nLONG signal: close USDJPY/USDCAD longs and EURUSD/XAUUSD shorts.\nSHORT signal: reverse above.\nDXY: {{close}} | {{time}}")
alertcondition(dxy_tp_hit or dxy_sl_hit,
    title   = "DXY Exit — TP or SL",
    message = "DXY EXIT — Close all pair positions now.\nDXY has hit its TP or SL level. Exit EURUSD, USDJPY, USDCAD, XAUUSD.\nDXY: {{close}} | {{time}}")
